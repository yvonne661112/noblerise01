---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.origin ?? 'https://noblerise.com.tw';
const imgUrl = (file: string) => `${siteOrigin}${base}${file}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "策略夥伴 | 諾昇理財規劃",
  "description": "諾昇理財規劃顧問策略夥伴團隊，結合會計師、律師、勞動法令顧問、信託顧問等專業，為客戶提供全方位的財務與法務支援。",
  "url": "https://noblerise.com.tw/about/策略夥伴/",
  "mainEntity": {
    "@type": "Organization",
    "name": "諾昇理財規劃顧問股份有限公司",
    "member": [
      { "@type": "Person", "name": "莊世金", "jobTitle": "會計師", "image": imgUrl("images/partner-chuang.jpg") },
      { "@type": "Person", "name": "賴瑩真", "jobTitle": "律師",   "image": imgUrl("images/partner-lai.jpg") },
      { "@type": "Person", "name": "劉奕男", "jobTitle": "顧問",   "image": imgUrl("images/partner-liu.png") },
      { "@type": "Person", "name": "陳慶榮", "jobTitle": "CFP 顧問","image": imgUrl("images/partner-chen.jpg") }
    ]
  }
};
---
<BaseLayout
  title="策略夥伴 | 諾昇理財規劃"
  description="諾昇理財規劃顧問策略夥伴團隊，結合會計師、律師、勞動法令顧問、信託顧問等專業，為客戶提供全方位的財務與法務支援。"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <PageHero
    eyebrow="Strategic Partners"
    title="諾昇策略夥伴<br/><span class='hero-mid'>專業組隊，一站對接，全方位守護您的資產</span>"
    description="財稅、法律、勞務、信託四大專業整合，以制度管理風險，以規劃創造價值<br/>諾昇策略團隊都在這裡，為您的家庭與事業保駕護航"
  />

  <!-- ── STATS BAR ── -->
  <div class="stat-bar">
    <div class="stat-item">
      <span class="stat-number">4</span>
      <span class="stat-label">專業領域</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">20+</span>
      <span class="stat-label">年平均資歷</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">1</span>
      <span class="stat-label">整合平台</span>
    </div>
  </div>

  <!-- ── INTRO BANNER ── -->
  <div class="sp-intro-banner">
    <div class="sp-intro-icon">
      <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22" aria-hidden="true">
        <path d="M11 2L13.5 8H20L14.5 12L16.5 18.5L11 14.5L5.5 18.5L7.5 12L2 8H8.5L11 2Z"
          stroke="white" stroke-width="1.5" stroke-linejoin="round"/>
      </svg>
    </div>
    <p class="sp-intro-text">
      諾昇深知，財富管理從來不是單一面向的事。企業主面對的挑戰橫跨<strong>財稅合規、法律風險、勞務管理與資產傳承</strong>，每一面都牽一髮動全身。正因如此，我們整合了多位具深厚資歷的策略夥伴，在諾昇財務顧問的統籌下，為客戶提供真正<strong>一站式、跨域整合</strong>的顧問服務。
    </p>
  </div>

  <!-- ── PARTNERS ── -->
  <main class="sp-partners">
    <div class="sp-section-header">
      <h2>合作夥伴介紹</h2>
      <div class="sp-section-line"></div>
    </div>

    <!-- 莊世金 -->
    <article class="sp-card">
      <div class="sp-card-photo">
        <img src={base + "images/partner-chuang.jpg"} alt="莊世金 會計師" loading="lazy" width="280" height="360">
        <div class="sp-card-overlay">
          <div class="sp-card-name">莊世金</div>
          <div class="sp-card-title-over">會計師</div>
        </div>
      </div>
      <div class="sp-card-body">
        <span class="sp-card-firm">萬騰聯合會計師事務所</span>
        <div class="sp-tags">
          <span class="sp-tag">股權規劃</span>
          <span class="sp-tag">稅務節稅</span>
          <span class="sp-tag">境外架構</span>
          <span class="sp-tag">財報簽證</span>
          <span class="sp-tag">內控設計</span>
          <span class="sp-tag">稅務諮詢</span>
        </div>
        <div class="sp-divider"></div>
        <p class="sp-card-desc">
          執業會計師，法學×財會跨域，政大法律研究所碩士在職；現正進行法學博士研習，並投考律師考試中。具會計師、稅務代理人、不動產經紀人與仲裁人資格。專精中小企業股權規劃、內控設計、稅務申報與節稅策略、財報/所得稅簽證、境外架構、稅務爭議與商務糾紛調解。
        </p>
        <div class="sp-collab">
          與諾昇財務顧問合作，將財稅法遵與資產/傳承規劃整合落地，降低風險、優化現金流與成本，強化企業治理與接班布局。
        </div>
      </div>
    </article>

    <!-- 賴瑩真 -->
    <article class="sp-card">
      <div class="sp-card-photo">
        <img src={base + "images/partner-lai.jpg"} alt="賴瑩真 律師" loading="lazy" width="280" height="360">
        <div class="sp-card-overlay">
          <div class="sp-card-name">賴瑩真</div>
          <div class="sp-card-title-over">律師</div>
        </div>
      </div>
      <div class="sp-card-body">
        <span class="sp-card-firm">詠言法律事務所（所長）</span>
        <div class="sp-tags">
          <span class="sp-tag">遺囑傳承</span>
          <span class="sp-tag">公司治理</span>
          <span class="sp-tag">智產訴訟</span>
          <span class="sp-tag">家事法務</span>
          <span class="sp-tag">影視授權</span>
          <span class="sp-tag">不動產諮詢</span>
        </div>
        <div class="sp-divider"></div>
        <p class="sp-card-desc">
          現任詠言法律事務所所長，長期承辦代筆遺囑、公司經營權紛爭、證券交易法、大型工程與不動產糾紛、智慧財產權等重大案件，具備深厚訴訟與企業法務經驗。賴律師亦在影視產業與家事案件深耕多年，熟悉影視授權、合作協議、著作權訴訟及完整的家族傳承法律策略規劃。
        </p>
        <div class="sp-collab">
          諾昇理財規劃顧問將結合賴瑩真律師的法務專業，為客戶提供更全方位、長期且具前瞻性的風險管理與法律保障，協助個人與企業安心邁向穩健發展。
        </div>
      </div>
    </article>

    <!-- 劉奕男 -->
    <article class="sp-card">
      <div class="sp-card-photo">
        <img src={base + "images/partner-liu.png"} alt="劉奕男 顧問" loading="lazy" width="280" height="360">
        <div class="sp-card-overlay">
          <div class="sp-card-name">劉奕男</div>
          <div class="sp-card-title-over">執行顧問</div>
        </div>
      </div>
      <div class="sp-card-body">
        <span class="sp-card-firm">丞翊企管執行顧問</span>
        <div class="sp-tags">
          <span class="sp-tag">勞動法令</span>
          <span class="sp-tag">勞資爭議</span>
          <span class="sp-tag">薪資設計</span>
          <span class="sp-tag">職災風險</span>
          <span class="sp-tag">工作規則</span>
          <span class="sp-tag">社保救濟</span>
        </div>
        <div class="sp-divider"></div>
        <p class="sp-card-desc">
          丞翊企管顧問執行顧問，具勞動法令、企業風險管理與社會保險救濟實務，長期為企業內訓與勞務制度健診，協助建置勞動契約、工作規則與薪資設計，降低職災、勞資爭議與賠償風險。
        </p>
        <div class="sp-collab">
          與諾昇財務顧問合作，將勞務合規與財稅規劃整合，為中小企業主提供一站式諮詢：用制度控風險、用稅務優化成本與現金流，提升用人成本效率並強化企業永續經營。
        </div>
      </div>
    </article>

    <!-- 陳慶榮 -->
    <article class="sp-card">
      <div class="sp-card-photo">
        <img src={base + "images/partner-chen.jpg"} alt="陳慶榮 CFP 顧問" loading="lazy" width="280" height="360">
        <div class="sp-card-overlay">
          <div class="sp-card-name">陳慶榮</div>
          <div class="sp-card-title-over">CFP 顧問</div>
        </div>
      </div>
      <div class="sp-card-body">
        <span class="sp-card-firm">威瑞財富（董事長）暨執業顧問</span>
        <div class="sp-tags">
          <span class="sp-tag">家族信託</span>
          <span class="sp-tag">股權移轉</span>
          <span class="sp-tag">員工福利</span>
          <span class="sp-tag">長照安養</span>
          <span class="sp-tag">資產傳承</span>
          <span class="sp-tag">CFP 認證</span>
        </div>
        <div class="sp-divider"></div>
        <p class="sp-card-desc">
          威瑞財富董事長暨執業顧問，財管15年。跨建築營建與金融保險背景，深耕信託：從家族資產傳承、股權移轉、員工福利到身心障礙者安養照護，以稅務與風險視角設計可執行的信託架構；並曾與多家銀行信託部合作。
        </p>
        <div class="sp-collab">
          和諾昇財務顧問合作提供獨立、透明且可落地的整合規劃，陪您把「想法」變成「可運作的制度」，適合企業主與需要長照監護安排的家庭。
        </div>
      </div>
    </article>
  </main>

  <!-- ── VALUE SECTION ── -->
  <section class="section sp-value-section">
    <div class="container">
      <div class="text-center mb-48">
        <span class="section-eyebrow">Why Noblerise</span>
        <h2 class="section-title">與諾昇策略聯盟合作的核心優勢</h2>
      </div>
      <div class="sp-value-grid">
        <div class="sp-value-card">
          <div class="sp-value-num">01</div>
          <h3>一站式跨域整合</h3>
          <p>財稅、法律、勞務、信託四大領域無縫合作，客戶無需分頭尋找多家專業機構，諾昇統籌協調，一次解決。</p>
        </div>
        <div class="sp-value-card">
          <div class="sp-value-num">02</div>
          <h3>超越部署・預防優先</h3>
          <p>從股權規劃、遺囑安置到勞務合規，我們建立制度，避免家庭糾紛、稅務裂縫與勞資爭議等事後高代價。</p>
        </div>
        <div class="sp-value-card">
          <div class="sp-value-num">03</div>
          <h3>三維風險管控</h3>
          <p>稅務風險、法律風險、勞務風險同步評估，再以信託架構與資產保全，形成完整防護網。</p>
        </div>
        <div class="sp-value-card">
          <div class="sp-value-num">04</div>
          <h3>規劃落地・制度可行</h3>
          <p>專業策略夥伴強調「可執行」落地方案，陪伴您把合規的想法變成可運作的制度與架構。</p>
        </div>
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  /* ── HERO DESC ── */
  :global(.hero-mid) {
    display: block;
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 400;
    margin-top: 8px;
    line-height: 1.5;
  }
  :global(.page-hero-desc) {
    font-size: 18px !important;
    color: #fff !important;
    font-weight: normal !important;
    max-width: 720px !important;
  }
  /* ── INTRO BANNER ── */
  .sp-intro-banner {
    background: var(--color-accent-pale);
    padding: 3rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border-accent);
    text-align: center;
  }
  .sp-intro-icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    background: var(--color-accent);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sp-intro-text {
    font-size: 18px;
    color: var(--color-text-mid);
    line-height: 1.9;
    max-width: 880px;
  }
  .sp-intro-text strong {
    color: var(--color-primary);
    font-weight: 500;
  }

  /* ── PARTNERS ── */
  .sp-partners {
    padding: 72px 4rem;
    max-width: 1160px;
    margin: 0 auto;
  }
  .sp-section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 48px;
  }
  .sp-section-header h2 {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: var(--heading-weight);
    color: var(--color-primary);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .sp-section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border-accent), transparent);
  }

  /* partner card */
  .sp-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    border: 1px solid var(--color-border-accent);
    border-radius: var(--card-radius);
    margin-bottom: 28px;
    overflow: hidden;
    background: var(--color-white);
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .sp-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-3px);
  }

  .sp-card-photo {
    position: relative;
    background: var(--color-primary);
    overflow: hidden;
    min-height: 300px;
  }
  .sp-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    opacity: 0.9;
    transition: opacity 0.3s, transform 0.4s;
  }
  .sp-card:hover .sp-card-photo img {
    opacity: 1;
    transform: scale(1.03);
  }
  .sp-card-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 48%;
    background: linear-gradient(to top, var(--hero-overlay), transparent);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px 18px;
  }
  .sp-card-name {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: var(--heading-weight);
    color: var(--color-on-primary);
    letter-spacing: 0.06em;
    line-height: 1.2;
  }
  .sp-card-title-over {
    font-size: 15px;
    color: #fff;
    margin-top: 4px;
    letter-spacing: 0.08em;
  }

  .sp-card-body {
    padding: 32px 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .sp-card-firm {
    display: inline-flex;
    align-items: center;
    font-size: 16px;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 1.1rem;
    background: var(--color-accent-pale);
    padding: 5px 12px;
    border-radius: 4px;
    border: 1px solid var(--color-border-accent);
    align-self: flex-start;
  }
  .sp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 1.1rem;
  }
  .sp-tag {
    font-size: 11.5px;
    color: var(--color-primary);
    background: var(--color-bg-subtle);
    padding: 4px 11px;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    letter-spacing: 0.02em;
  }
  .sp-divider {
    width: 28px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: 1rem;
    border-radius: 2px;
  }
  .sp-card-desc {
    font-size: 16px;
    color: var(--color-text-mid);
    line-height: 1.9;
    margin-bottom: 1.1rem;
  }
  .sp-collab {
    font-size: 15.5px;
    color: var(--color-primary);
    line-height: 1.85;
    padding: 13px 16px;
    background: var(--color-accent-pale);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 6px 6px 0;
  }

  /* ── VALUE SECTION ── */
  .sp-value-section {
    background: var(--color-accent-pale);
    border-top: 4px solid var(--color-accent);
  }
  .sp-value-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .sp-value-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 20px;
    border-radius: var(--card-radius);
    border: 1px solid var(--color-border);
    background: var(--color-white);
    transition: box-shadow 0.25s, transform 0.25s, border-color 0.25s;
  }
  .sp-value-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-3px);
    border-color: var(--color-accent);
  }
  .sp-value-num {
    width: 56px;
    height: 56px;
    background: var(--color-accent-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-family: var(--font-heading);
    font-size: var(--fs-2xl, 24px);
    font-weight: 700;
    color: var(--color-primary);
    transition: background 0.25s, color 0.25s;
  }
  .sp-value-card:hover .sp-value-num {
    background: var(--color-accent);
    color: var(--color-white);
  }
  .sp-value-card h3 {
    font-family: var(--font-heading);
    font-size: var(--fs-xl, 20px);
    font-weight: var(--heading-weight);
    color: var(--color-accent);
    margin-bottom: 12px;
  }
  .sp-value-card p {
    font-size: var(--fs-lg, 18px);
    color: var(--color-text-mid);
    line-height: 1.7;
  }

  /* ── MOBILE ── */
  @media (max-width: 900px) {
    .sp-intro-banner { padding: 2.5rem 1.5rem; flex-direction: column; }
    .sp-partners { padding: 48px 1.5rem; }
    .sp-card { grid-template-columns: 1fr; }
    .sp-card-photo { min-height: 240px; }
    .sp-card-body { padding: 24px 20px; }
    .sp-value-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .sp-value-grid { grid-template-columns: 1fr; }
  }
</style>
