---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { CONTACT, SHOW_CTA } from '../../data/siteConfig';

const base = import.meta.env.BASE_URL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "關於諾昇 | 張惠芳 CFP® | 諾昇理財規劃",
  "description": "諾昇以財務幸福為核心，由 CFP® 張惠芳領軍，以獨立理財顧問（IFA）立場提供中立、專業的財務建議。",
  "url": `${CONTACT.siteUrl}/about/`,
  "mainEntity": {
    "@type": "Person",
    "name": "張惠芳",
    "url": `${CONTACT.siteUrl}/about/`,
    "image": `${CONTACT.siteUrl}/images/yvonne-about.png`,
    "jobTitle": "CFP® 國際認證高級理財規劃顧問",
    "description": "諾昇理財執行長／首席規劃顧問。20 年金融實務經驗，堅持「不賣產品、只做規劃」的獨立顧問模式。",
    "worksFor": {
      "@type": "Organization",
      "name": CONTACT.companyNameZh
    },
    "hasCredential": [
      "CFP® 國際認證高級理財規劃顧問",
      "RFA 退休理財規劃顧問",
      "FChFP 特許財務規劃師",
      "家族信託規劃顧問師"
    ],
    "award": [
      "FChFP 國際特許財務規劃師",
      "2021 FPAT 理財規劃書競賽 團體組第二名",
      "2022 FPAT 理財規劃書競賽 最佳顧問獎"
    ],
    "sameAs": [
      "https://www.facebook.com/noblerisefinancial",
      `${CONTACT.siteUrl}/`
    ]
  }
};
---
<BaseLayout
  title="關於諾昇 | 張惠芳 CFP® | 諾昇理財規劃"
  description="諾昇以財務幸福為核心，由 CFP® 張惠芳領軍，以獨立理財顧問（IFA）立場提供中立、專業的財務建議。了解諾昇的理念與首席顧問背景。"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <PageHero
    title="以財務幸福為信念<br/>用專業陪伴每一個家庭"
    backgroundImage="images/aboutmehead.jpg"
  />

  <!-- ▸ STATS BAR -->
  <div class="stat-bar" id="stat-bar">
    <div class="stat-item">
      <span class="stat-number" data-count="20" data-suffix="+">0</span>
      <span class="stat-label">年金融實務經驗</span>
    </div>
    <div class="stat-item">
      <span class="stat-number stat-cfp-wrap">
        <a href="https://www.fpat.org.tw/LecturerResume/SearchPage/5009" target="_blank" rel="noopener nofollow noreferrer"><img src={base + "images/cfp-logo.png"} alt="CFP® 國際認證" class="stat-cfp-logo" /></a>
      </span>
      <span class="stat-label">國際認證高級理財規劃顧問</span>
    </div>
    <div class="stat-item">
      <span class="stat-number stat-cfp-wrap">
        <img src={base + "images/fchfp-logo.jpg"} alt="FChFP 特許財務規劃師" class="stat-cfp-logo" />
      </span>
      <span class="stat-label">特許財務規劃師</span>
    </div>
    <div class="stat-item">
      <span class="stat-number" data-count="6">0</span>
      <span class="stat-label">大媒體專欄作家</span>
    </div>
  </div>

  <script>
    const bar = document.getElementById('stat-bar');
    if (bar) {
      const counters = bar.querySelectorAll('[data-count]');
      let animated = false;
      const animate = () => {
        if (animated) return;
        animated = true;
        counters.forEach(el => {
          const target = parseInt(el.getAttribute('data-count')!, 10);
          const suffix = el.getAttribute('data-suffix') || '';
          const duration = 1200;
          const start = performance.now();
          const tick = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(eased * target) + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      };
      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) { animate(); obs.disconnect(); }
      }, { threshold: 0.5 });
      obs.observe(bar);
    }
  </script>

  <main>
    <!-- ▸ 首席顧問 -->
    <section class="section section-subtle">
      <div class="container">
        <div class="advisor-profile">
          <div class="advisor-photo-col">
            <img src={base + "images/yvonne-about.png"} alt="張惠芳 CFP® 首席理財規劃顧問" width="400" height="400" loading="lazy" class="advisor-portrait" />
            <div class="advisor-certs">
              <span class="credential-badge"><a href="https://www.fpat.org.tw/LecturerResume/SearchPage/5009" target="_blank" rel="noopener nofollow noreferrer">CFP® 國際認證高級理財規劃顧問</a></span>
              <span class="credential-badge">RFA 退休理財顧問</span>
              <span class="credential-badge">FChFP 特許財務規劃師</span>
              <span class="credential-badge">家族信託規劃顧問師</span>
            </div>
          </div>
          <div class="advisor-detail">
            <h2 class="section-title">張惠芳 CFP®</h2>
            <p class="advisor-bio">國際認證高級理財規劃顧問 CFP® 張惠芳是諾昇的創辦人兼首席理財規劃顧問。她以 20 年金融實務經驗，建立諾昇的服務理念與方法，深入了解您的價值觀、財務現況、風險需求及期待達成的財務目標（買房、教育金、退休、貸款、傳承等議題），資料彙整與分析後量身訂製執行方案，確保每一項財務建議都以客戶利益為核心出發點，陪伴客戶走向財務幸福！</p>

            <div class="detail-block">
              <h3 class="detail-title">現職</h3>
              <ul class="detail-list">
                <li>諾昇理財規劃顧問公司執行長</li>
                <li>詠言法律事務所 稅務顧問</li>
                <li>威瑞財富管理 信託團隊</li>
                <li>專欄作家：風傳媒、天下雜誌、今周刊、Smart 自學網、橘世代、好險有錢</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3 class="detail-title">專業經歷</h3>
              <ul class="detail-list">
                <li>臺灣理財認證顧問協會「從員工福利信託看員工財務規劃」講師</li>
                <li>金融研訓院 成人金融素養教育 講師</li>
                <li>理財好聲音 極客年會財務規劃 講師</li>
                <li>受邀於政大、淡江、文化大學、台電、竹北主婦聯盟、FPAT、菁英財管、中華職能應用發展協會、公勝保經、三商美邦人壽等單位演講</li>
              </ul>
            </div>

            <div class="detail-block">
              <h3 class="detail-title">媒體曝光</h3>
              <ul class="detail-list media-exposure">
                <li><strong>天下雜誌</strong>：<a href="https://www.cw.com.tw/article/5138572?tos=true" target="_blank" rel="noopener nofollow noreferrer">所得替代率是什麼？一張表看懂你需要多少退休金</a></li>
                <li><strong>風傳媒</strong>：<a href="https://www.storm.mg/lifestyle/11112031" target="_blank" rel="noopener nofollow noreferrer">康橋、復興、靜心學費大公開！私立、公立學校學費差多少？過來人曝：不只學費，「1隱形成本」就破百萬</a></li>
                <li><strong>橘世代</strong>：<a href="https://orange.udn.com/orange/story/121196/8923151" target="_blank" rel="noopener nofollow noreferrer">60歲前存滿2千萬，可原地退休？小資夫妻靠4策略「永遠有錢花」</a></li>
                <li><strong>Smart自學網</strong>：<a href="https://smart.businessweekly.com.tw/Reading/IndepArticle.aspx?id=6017240" target="_blank" rel="noopener nofollow noreferrer">遇到車禍不要慌！6步驟教你正確報案，完整SOP教你保障理賠權利</a></li>
                <li><strong>BabyHome</strong>：<a href="https://forum.babyhome.com.tw/article/5042928" target="_blank" rel="noopener nofollow noreferrer">台灣養孩子的低標和富養孩子費用是多少？看看你家是哪一種</a></li>
                <li><strong>FPAT Podcast</strong>：<a href="https://solink.soundon.fm/episode/5c950785-667b-4cd3-bc5a-2d108321a0c0" target="_blank" rel="noopener nofollow noreferrer">EP7 理財小白的財務重生故事</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ▸ 獲獎紀錄 -->
    <section class="section">
      <div class="container">
        <div class="text-center mb-48">
          <h2 class="section-title">獲獎紀錄</h2>
        </div>
        <div class="awards-grid">
          <div class="award-card reveal">
            <img src={base + "images/award1.jpg"} alt="FChFP 國際特許財務規劃師授證" width="360" height="270" loading="lazy" class="award-img" />
            <div class="award-body">
              <h3>FChFP 國際特許財務規劃師</h3>
              <p>Fellow Chartered Financial Practitioner 授證</p>
            </div>
          </div>
          <div class="award-card reveal">
            <img src={base + "images/award3.jpg"} alt="2021 FPAT 理財規劃書競賽 團體組第二名" width="360" height="270" loading="lazy" class="award-img" />
            <div class="award-body">
              <h3>FPAT 理財規劃書競賽</h3>
              <p>2021 團體組 第二名</p>
            </div>
          </div>
          <div class="award-card reveal">
            <img src={base + "images/award2.jpg"} alt="2022 FPAT 理財規劃書競賽 最佳顧問獎" width="360" height="270" loading="lazy" class="award-img" />
            <div class="award-body">
              <h3>FPAT 理財規劃書競賽</h3>
              <p>2022 最佳顧問獎</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ▸ CTA */}
    {SHOW_CTA && (
    <section class="section section-primary cta-section">
      <div class="container text-center">
        <h2 class="section-title" style="color: var(--color-on-primary)">想和我們聊聊你的財務目標？</h2>
        <p style="color: rgba(255,255,255,0.8); font-size: var(--fs-lg); max-width: 520px; margin: 0 auto 36px;">30 分鐘免費諮詢，釐清方向、無壓力。</p>
        <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn btn-accent btn-lg">LINE 預約諮詢</a>
      </div>
    </section>
    )}
  </main>


</BaseLayout>

<style>
  /* ── CFP LOGO ── */
  .stat-cfp-wrap {
    display: flex !important;
    align-items: center;
    justify-content: center;
    min-height: 65px;
  }
  .stat-cfp-logo {
    height: 52px;
    width: auto;
    display: block;
  }
  #stat-bar .stat-number {
    min-height: 65px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── MISSION ── */
  .about-mission {
    font-size: var(--fs-xl);
    font-weight: 700;
    line-height: 2;
    text-align: center;
    max-width: 860px;
    margin: 0 auto;
    color: var(--color-text);
  }

  /* ── ADVISOR PROFILE ── */
  .advisor-profile {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 64px;
    align-items: start;
  }
  .advisor-photo-col {
    position: sticky;
    top: 100px;
  }
  .advisor-portrait {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 24px;
  }
  .advisor-certs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .advisor-tagline {
    font-size: var(--fs-md);
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .advisor-bio {
    font-size: var(--fs-lg);
    font-weight: 400;
    line-height: 1.9;
    margin-bottom: 32px;
  }

  .detail-block {
    margin-bottom: 28px;
  }
  .detail-title {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--heading-weight);
    color: var(--color-primary);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
  }
  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .detail-list li {
    padding: 8px 0 8px 20px;
    position: relative;
    font-size: var(--fs-body);
    font-weight: 400;
    line-height: 1.8;
    color: var(--color-text);
  }
  .detail-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 16px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* ── MEDIA EXPOSURE ── */
  .media-exposure li {
    font-size: var(--fs-base);
    font-weight: 400;
  }
  .media-exposure a {
    color: var(--color-link);
    text-decoration: underline;
  }
  .media-exposure a:hover {
    color: var(--color-primary);
  }

  /* ── AWARDS ── */
  .awards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 960px;
    margin: 0 auto;
  }
  .award-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    overflow: hidden;
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .award-card:hover {
    box-shadow: var(--card-shadow-hover);
  }
  .award-img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
    transition: aspect-ratio 0.3s ease, object-fit 0.3s ease;
  }
  .award-card:hover .award-img {
    aspect-ratio: auto;
  }
  .award-body {
    padding: 20px 24px;
  }
  .award-body h3 {
    font-family: var(--font-heading);
    font-size: var(--fs-base);
    font-weight: var(--heading-weight);
    color: var(--color-primary);
    margin-bottom: 4px;
  }
  .award-body p {
    font-size: var(--fs-sm);
    color: var(--color-text-mid);
  }

  /* ── CTA ── */
  .cta-section {
    background-image: var(--hero-pattern);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .advisor-profile {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .advisor-photo-col {
      position: static;
      max-width: 320px;
      margin: 0 auto;
      text-align: center;
    }
    .advisor-certs { justify-content: center; }
    .awards-grid { grid-template-columns: 1fr; max-width: 400px; }
  }
</style>
