---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { SHOW_BOOKING, SHOW_CTA, CONTACT } from '../../data/siteConfig';

const base = import.meta.env.BASE_URL;

const provider = {
  "@type": "FinancialService",
  "name": CONTACT.companyNameZh,
  "url": CONTACT.siteUrl
};

const services = [
  { name: "收支管理與財務盤點", description: "全面釐清收入與支出結構，建立可持續的財務管理架構，讓每一筆錢都花在對的地方。" },
  { name: "保險保障規劃", description: "以第三方角度審視現有保單，揪出多餘保障與不當商品，花更少保費、享更好保障。" },
  { name: "教育與家庭目標規劃", description: "為孩子教育金、買房購車等家庭里程碑做好財務準備，讓夢想有實現的時間表。" },
  { name: "房產與重大資產決策", description: "理性評估買房時機與金額，做出聰明的資產配置決策，避免過度負債。" },
  { name: "退休與投資策略", description: "科學規劃退休金缺口、設定合理投資目標，讓未來的自己無後顧之憂。" },
  { name: "傳承與高齡照護規劃", description: "信託、稅務、傳承一站規劃。提前設計資產流向，守護家族財富，避免爭議。" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "服務項目 | 諾昇理財規劃",
  "description": "諾昇提供收支管理、資產管理、風險管理、財務規劃、稅務規劃、傳承規劃等全方位服務，提供30分鐘免費線上諮詢。",
  "url": `${CONTACT.siteUrl}/service/`,
  "mainEntity": services.map(s => ({
    "@type": "Service",
    "name": s.name,
    "description": s.description,
    "provider": provider
  }))
};
---
<BaseLayout
  title="服務項目 | 諾昇理財規劃"
  description="諾昇提供收支管理、資產管理、風險管理、財務規劃、稅務規劃、傳承規劃等全方位服務，提供30分鐘免費線上諮詢。"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <PageHero
    eyebrow="Services"
    title="讓金流更清楚<br/>未來更安心"
    description="不推銷、不賣產品，只用策略把「現在的資源」連結到「你想要的生活」。"
    backgroundImage="images/aboutmehead.jpg"
  />

  <main>
    <!-- ▸ 服務理念 -->
    <section class="section">
      <div class="container narrow-container">
        <div class="text-center">
          <span class="section-eyebrow">Our Approach</span>
          <h2 class="section-title">財務規劃，不是報告</h2>
          <hr class="section-divider section-divider--center" />
        </div>
        <p class="service-philosophy">面對眾多理財資訊與商品，您是否常常不知如何判斷？努力理財卻沒有回報？想開始規劃，卻不知道第一步？在諾昇，財務規劃是陪你真正做好財務 — 用策略把「現在的資源」連結到「想要的生活」，一起把財務幸福做到位。</p>
      </div>
    </section>

    <!-- ▸ 六大服務 -->
    <section class="section section-subtle">
      <div class="container">
        <div class="text-center mb-48">
          <span class="section-eyebrow">What We Do</span>
          <h2 class="section-title">六大服務領域</h2>
        </div>
        <div class="service-icon-grid">
          <div class="service-icon-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M5 9.2h3V19H5V9.2zm5.6-4.2h2.8v14h-2.8V5zm5.6 8h2.8v6h-2.8v-6z"/>
              </svg>
            </div>
            <h3>收支管理與財務盤點</h3>
            <p>全面釐清收入與支出結構，建立可持續的財務管理架構，讓每一筆錢都花在對的地方。</p>
          </div>
          <div class="service-icon-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
              </svg>
            </div>
            <h3>保險保障規劃</h3>
            <p>以第三方角度審視現有保單，揪出多餘保障與不當商品，花更少保費、享更好保障。</p>
          </div>
          <div class="service-icon-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
              </svg>
            </div>
            <h3>教育與家庭目標規劃</h3>
            <p>為孩子教育金、買房購車等家庭里程碑做好財務準備，讓夢想有實現的時間表。</p>
          </div>
          <div class="service-icon-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
            </div>
            <h3>房產與重大資產決策</h3>
            <p>理性評估買房時機與金額，做出聰明的資產配置決策，避免過度負債。</p>
          </div>
          <div class="service-icon-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
              </svg>
            </div>
            <h3>退休與投資策略</h3>
            <p>科學規劃退休金缺口、設定合理投資目標，讓未來的自己無後顧之憂。</p>
          </div>
          <div class="service-icon-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
              </svg>
            </div>
            <h3>傳承與高齡照護規劃</h3>
            <p>信託、稅務、傳承一站規劃。提前設計資產流向，守護家族財富，避免爭議。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ▸ 傳承規劃重點 -->
    <section class="section">
      <div class="container">
        <div class="inheritance-block">
          <div class="inheritance-content">
            <span class="section-eyebrow">Inheritance Planning</span>
            <h2 class="section-title">傳承規劃</h2>
            <hr class="section-divider" />
            <p>傳承規劃不僅是財產分配，更是為家人避開未來高成本風險的重要準備。若缺乏事前設計，家人可能面臨資產凍結、稅負提高、分配爭議與流程延誤。</p>
            <p class="mt-16">透過專業協作，提前設計稅務、信託與資產流向，讓財富分配更清楚、合法節稅，並確保資產確實留給最重要的人。</p>
            <p class="service-highlight mt-24">傳承要得早布局；現在的準備，就是給家人未來最實在的安心。</p>
          </div>
          <div class="inheritance-visual">
            <div class="card">
              <div class="card-img">
                <img src={base + "images/home-item3.jpg"} alt="財務規劃" width="400" height="250" loading="lazy" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ▸ 六步驟 -->
    <section class="section section-subtle">
      <div class="container">
        <div class="text-center mb-48">
          <span class="section-eyebrow">Process</span>
          <h2 class="section-title">財務規劃六步驟</h2>
        </div>
        <img src={base + "images/財務規劃六步驟00.png"} alt="財務規劃六步驟" loading="lazy" class="service-full-img mb-32" />
        <div class="steps-grid">
          <div class="step-card">
            <img src={base + "images/財務規劃六步驟01.png"} alt="步驟 1" loading="lazy" />
          </div>
          <div class="step-card">
            <img src={base + "images/財務規劃六步驟02.png"} alt="步驟 2" loading="lazy" />
          </div>
          <div class="step-card">
            <img src={base + "images/財務規劃六步驟03.png"} alt="步驟 3" loading="lazy" />
          </div>
          <div class="step-card">
            <img src={base + "images/財務規劃六步驟04.png"} alt="步驟 4" loading="lazy" />
          </div>
          <div class="step-card">
            <img src={base + "images/財務規劃六步驟05.png"} alt="步驟 5" loading="lazy" />
          </div>
          <div class="step-card">
            <img src={base + "images/財務規劃六步驟06.png"} alt="步驟 6" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ▸ 免費諮詢 CTA */}
    {SHOW_CTA && (
    <section class="section section-primary cta-section">
      <div class="container">
        <div class="cta-layout">
          <div class="cta-content">
            <span class="section-eyebrow" style="color: var(--color-accent-light)">Free Consultation</span>
            <h2 class="section-title" style="color: var(--color-on-primary)">30 分鐘免費諮詢</h2>
            <p style="color: rgba(255,255,255,0.8); margin-bottom: 24px;">若您想進一步了解財務規劃，我們提供 30 分鐘免費線上諮詢。協助釐清您的財務現況是否需要規劃，並說明諾昇的流程、服務內容與收費方式。</p>
            <p style="color: var(--color-on-primary); font-weight: 600; margin-bottom: 32px;">您將帶走清楚的下一步方向，以及選擇最適合自己方案所需的完整資訊。</p>
            <div class="cta-buttons">
              <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn btn-accent btn-lg">LINE 預約諮詢</a>
              {SHOW_BOOKING && (
                <a href={base + "contact/"} class="btn btn-outline-light">預約免費諮詢</a>
              )}
            </div>
          </div>
          <div class="cta-notes">
            <div class="note-card">
              <h4>諮詢定位</h4>
              <p>僅提供流程說明與方向建議，不含個別深入分析</p>
            </div>
            <div class="note-card">
              <h4>內容限制</h4>
              <p>30 分鐘內不針對個人財務問題提供具體解決方案</p>
            </div>
            <div class="note-card">
              <h4>法律聲明</h4>
              <p>本服務屬財務顧問性質，非投資或證券買賣建議</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    )}

    <!-- ▸ 補充服務卡 -->
    <section class="section section-subtle">
      <div class="container">
        <div class="grid-3">
          <div class="card">
            <div class="card-img">
              <img src={base + "images/home-item1.jpg"} alt="收支管理/資產管理" width="400" height="250" loading="lazy" />
            </div>
            <div class="card-body">
              <h3>收支管理 ／ 資產管理</h3>
            </div>
          </div>
          <div class="card">
            <div class="card-img">
              <img src={base + "images/home-item2.jpg"} alt="信用管理/風險管理" width="400" height="250" loading="lazy" />
            </div>
            <div class="card-body">
              <h3>信用管理 ／ 風險管理</h3>
            </div>
          </div>
          <div class="card">
            <div class="card-img">
              <img src={base + "images/home-item3.jpg"} alt="財務規劃/稅務規劃" width="400" height="250" loading="lazy" />
            </div>
            <div class="card-body">
              <h3>財務規劃 ／ 稅務規劃</h3>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>


</BaseLayout>

<style>
  /* ── SERVICE PHILOSOPHY ── */
  .service-philosophy {
    font-size: var(--fs-lg);
    line-height: 2;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── SERVICE ICON GRID ── */
  .service-icon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .service-icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 20px;
    border-radius: var(--card-radius);
    border: 1px solid var(--color-border);
    background: var(--color-white);
    transition: box-shadow 0.25s, transform 0.25s, border-color 0.25s;
  }
  .service-icon-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-3px);
    border-color: var(--color-accent);
  }
  .service-icon-box {
    width: 88px;
    height: 88px;
    background: var(--color-accent-pale);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--color-primary);
    transition: background 0.25s, color 0.25s;
  }
  .service-icon-card:hover .service-icon-box {
    background: var(--color-accent);
    color: var(--color-white);
  }
  .service-icon-card h3 {
    font-family: var(--font-heading);
    font-size: var(--fs-lg);
    font-weight: var(--heading-weight);
    color: var(--color-accent);
    margin-bottom: 12px;
  }
  .service-icon-card p {
    font-size: var(--fs-base);
    color: var(--color-text-mid);
    line-height: 1.7;
  }

  /* ── INHERITANCE ── */
  .inheritance-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .inheritance-content p {
    line-height: 1.9;
  }
  .service-highlight { font-weight: 600; color: var(--color-accent); }

  /* ── STEPS ── */
  .service-full-img { width: 100%; height: auto; display: block; border-radius: var(--card-radius); }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .step-card img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--card-radius);
  }

  /* ── CTA ── */
  .cta-section {
    background-image: var(--hero-pattern);
  }
  .cta-layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .cta-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .cta-notes {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .note-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--card-radius);
    padding: 20px;
  }
  .note-card h4 {
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--color-accent-light);
    margin-bottom: 6px;
  }
  .note-card p {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .service-icon-grid { grid-template-columns: 1fr 1fr; }
    .inheritance-block { grid-template-columns: 1fr; gap: 32px; }
    .cta-layout { grid-template-columns: 1fr; gap: 32px; }
    .steps-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .service-icon-grid { grid-template-columns: 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
