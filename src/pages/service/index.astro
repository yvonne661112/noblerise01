---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionCard from '../../components/SectionCard.astro';
import { SHOW_BOOKING, SHOW_CTA, CONTACT } from '../../data/siteConfig';

const base = import.meta.env.BASE_URL;

const provider = {
  "@type": "FinancialService",
  "name": CONTACT.companyNameZh,
  "url": CONTACT.siteUrl
};

const services = [
  { name: "收支管理與財務盤點", description: "全面釐清收入與支出結構，建立可持續的財務管理架構，讓每一筆錢都花在對的地方。" },
  { name: "保險保障規劃", description: "以第三方角度審視現有保單，揪出多餘保障與不當商品，花更少保費、享更好保障。" },
  { name: "教育與家庭目標規劃", description: "為孩子教育金、買房購車等家庭里程碑做好財務準備，讓夢想有實現的時間表。" },
  { name: "房產與重大資產決策", description: "理性評估買房時機與金額，做出聰明的資產配置決策，避免過度負債。" },
  { name: "退休與投資策略", description: "科學規劃退休金缺口、設定合理投資目標，讓未來的自己無後顧之憂。" },
  { name: "傳承與高齡照護規劃", description: "信託、稅務、傳承一站規劃。提前設計資產流向，守護家族財富，避免爭議。" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "服務項目 | 諾昇理財規劃",
  "description": "諾昇提供收支管理、資產管理、風險管理、財務規劃、稅務規劃、傳承規劃等全方位服務，提供30分鐘免費線上諮詢。",
  "url": `${CONTACT.siteUrl}/service/`,
  "mainEntity": services.map(s => ({
    "@type": "Service",
    "name": s.name,
    "description": s.description,
    "provider": provider
  }))
};
---
<BaseLayout
  title="服務項目 | 諾昇理財規劃"
  description="諾昇提供收支管理、資產管理、風險管理、財務規劃、稅務規劃、傳承規劃等全方位服務，提供30分鐘免費線上諮詢。"
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <PageHero
    title="財務幸福<br/>由諾昇理財規劃陪伴您落地執行"
    backgroundImage="images/aboutmehead.jpg"
  />

  <main>
    <!-- ▸ 服務理念 -->
    <section class="section">
      <div class="container narrow-container">
        <div class="text-center">
          <h2 class="section-title">財務規劃，不是報告</h2>
        </div>
        <p class="service-philosophy">面對眾多理財資訊與商品，您是否常常不知如何判斷？努力理財卻沒有回報？想開始規劃，卻不知道第一步？</p>
        <p class="service-philosophy" style="margin-top: 16px;">在諾昇，財務規劃不是報告，而是陪您真正做好財務規劃 ，不推銷、不賣產品，只讓金流更清楚，未來更安心！用策略把「現在的資源」連結到「想要的生活」，一起把財務幸福做到位。</p>
      </div>
    </section>

    <!-- ▸ 六大服務 -->
    <section class="section section-subtle">
      <div class="container">
        <div class="text-center mb-48">
          <h2 class="section-title">六大服務領域</h2>
        </div>
        <div class="service-icon-grid">
          <SectionCard>
            <div class="section-card-icon-box" slot="icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M5 9.2h3V19H5V9.2zm5.6-4.2h2.8v14h-2.8V5zm5.6 8h2.8v6h-2.8v-6z"/>
              </svg>
            </div>
            <h3>收支管理與財務盤點</h3>
            <p>全面釐清收入與支出結構，建立可持續的財務管理架構，讓每一筆錢都花在對的地方。</p>
          </SectionCard>
          <SectionCard>
            <div class="section-card-icon-box" slot="icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
              </svg>
            </div>
            <h3>保險保障規劃</h3>
            <p>以第三方角度審視現有保單，揪出多餘保障與不當商品，花更少保費、享更好保障。</p>
          </SectionCard>
          <SectionCard>
            <div class="section-card-icon-box" slot="icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
              </svg>
            </div>
            <h3>教育與家庭目標規劃</h3>
            <p>為孩子教育金、買房購車等家庭里程碑做好財務準備，讓夢想有實現的時間表。</p>
          </SectionCard>
          <SectionCard>
            <div class="section-card-icon-box" slot="icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
            </div>
            <h3>房產與重大資產決策</h3>
            <p>理性評估買房時機與金額，做出聰明的資產配置決策，避免過度負債。</p>
          </SectionCard>
          <SectionCard>
            <div class="section-card-icon-box" slot="icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
              </svg>
            </div>
            <h3>退休與投資策略</h3>
            <p>科學規劃退休金缺口、設定合理投資目標，讓未來的自己無後顧之憂。</p>
          </SectionCard>
          <SectionCard>
            <div class="section-card-icon-box" slot="icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
              </svg>
            </div>
            <h3>傳承與高齡照護規劃</h3>
            <p>信託、稅務、傳承一站規劃。提前設計資產流向，守護家族財富，避免爭議。</p>
          </SectionCard>
        </div>
      </div>
    </section>

    <!-- ▸ 傳承規劃重點 -->
    <section class="section">
      <div class="container">
        <div class="inheritance-block">
          <div class="inheritance-content">
            <h2 class="section-title">傳承規劃</h2>
            <p>傳承規劃不僅是財產分配，更是為家人避開未來高成本風險的重要準備。若缺乏事前設計，家人可能面臨資產凍結、稅負提高、分配爭議與流程延誤。</p>
            <p class="mt-16">透過專業協作，提前設計稅務、信託與資產流向，讓財富分配更清楚、合法節稅，並確保資產確實留給最重要的人。</p>
            <p class="service-highlight mt-24">傳承要得早布局；現在的準備，就是給家人未來最實在的安心。</p>
          </div>
          <div class="inheritance-visual">
            <div class="inheritance-illustration">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 360" fill="none" aria-hidden="true">
                <rect width="400" height="360" rx="16" fill="var(--color-accent-pale)" />
                <!-- 第一代（祖父母） -->
                <circle cx="200" cy="50" r="20" fill="var(--color-primary)"/>
                <text x="200" y="56" text-anchor="middle" font-size="16" fill="white" font-weight="600">1</text>
                <text x="200" y="88" text-anchor="middle" font-size="13" fill="var(--color-primary)" font-weight="600">第一代</text>
                <!-- 連接線 第一代→第二代 -->
                <line x1="200" y1="70" x2="200" y2="100" stroke="var(--color-accent)" stroke-width="2"/>
                <line x1="120" y1="120" x2="280" y2="120" stroke="var(--color-accent)" stroke-width="2"/>
                <line x1="120" y1="100" x2="120" y2="120" stroke="var(--color-accent)" stroke-width="2"/>
                <line x1="200" y1="100" x2="200" y2="120" stroke="var(--color-accent)" stroke-width="2"/>
                <line x1="280" y1="100" x2="280" y2="120" stroke="var(--color-accent)" stroke-width="2"/>
                <!-- 第二代（子女） -->
                <circle cx="120" cy="140" r="17" fill="var(--color-accent)"/>
                <circle cx="200" cy="140" r="17" fill="var(--color-accent)"/>
                <circle cx="280" cy="140" r="17" fill="var(--color-accent)"/>
                <text x="120" y="145" text-anchor="middle" font-size="14" fill="white" font-weight="600">2</text>
                <text x="200" y="145" text-anchor="middle" font-size="14" fill="white" font-weight="600">2</text>
                <text x="280" y="145" text-anchor="middle" font-size="14" fill="white" font-weight="600">2</text>
                <text x="200" y="178" text-anchor="middle" font-size="13" fill="var(--color-accent)" font-weight="600">第二代</text>
                <!-- 連接線 第二代→第三代 -->
                <line x1="120" y1="157" x2="120" y2="195" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.6"/>
                <line x1="200" y1="157" x2="200" y2="195" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.6"/>
                <line x1="280" y1="157" x2="280" y2="195" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.6"/>
                <!-- 第三代（孫子女） -->
                <!-- 左組：兩個圓 + 橫線 -->
                <line x1="95" y1="198" x2="145" y2="198" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5"/>
                <circle cx="95" cy="212" r="12" fill="var(--color-primary)" opacity="0.5"/>
                <circle cx="145" cy="212" r="12" fill="var(--color-primary)" opacity="0.5"/>
                <!-- 中間：單圓 -->
                <circle cx="200" cy="212" r="12" fill="var(--color-primary)" opacity="0.5"/>
                <!-- 右組：兩個圓 + 橫線 -->
                <line x1="255" y1="198" x2="305" y2="198" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5"/>
                <circle cx="255" cy="212" r="12" fill="var(--color-primary)" opacity="0.5"/>
                <circle cx="305" cy="212" r="12" fill="var(--color-primary)" opacity="0.5"/>
                <text x="200" y="248" text-anchor="middle" font-size="13" fill="var(--color-primary)" opacity="0.6" font-weight="600">第三代</text>
                <!-- 資產項目：房產、信託（中間）、稅務 -->
                <!-- 房產 -->
                <rect x="40" y="265" width="90" height="55" rx="8" fill="white" stroke="var(--color-accent)" stroke-width="2"/>
                <path d="M85 275 L60 290 L60 310 L110 310 L110 290 Z" fill="var(--color-primary)" opacity="0.15" stroke="var(--color-primary)" stroke-width="1"/>
                <text x="85" y="340" text-anchor="middle" font-size="14" fill="var(--color-text-mid)" font-weight="700">房產</text>
                <!-- 信託（中間） -->
                <rect x="155" y="265" width="90" height="55" rx="8" fill="white" stroke="var(--color-accent)" stroke-width="2"/>
                <path d="M215 273 L215 295 C215 307 205 313 200 315 C195 313 185 307 185 295 L185 273 L200 269 L215 273 Z" fill="var(--color-accent)" opacity="0.3" stroke="var(--color-accent)" stroke-width="1"/>
                <path d="M194 291 L198 295 L207 285" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <text x="200" y="340" text-anchor="middle" font-size="14" fill="var(--color-accent)" font-weight="700">信託</text>
                <!-- 稅務 -->
                <rect x="270" y="265" width="90" height="55" rx="8" fill="white" stroke="var(--color-accent)" stroke-width="2"/>
                <rect x="300" y="275" width="30" height="38" rx="3" fill="var(--color-white)" stroke="var(--color-primary)" stroke-width="1" opacity="0.7"/>
                <text x="315" y="293" text-anchor="middle" font-size="14" fill="var(--color-primary)" opacity="0.6" font-weight="700">%</text>
                <text x="315" y="340" text-anchor="middle" font-size="14" fill="var(--color-text-mid)" font-weight="700">稅務</text>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ▸ 六步驟 -->
    <section class="section section-subtle">
      <div class="container">
        <div class="text-center mb-48">
          <h2 class="section-title">財務規劃六步驟</h2>
        </div>
        <div class="step-icon-grid">
          <SectionCard variant="number" number="1">
            <h3>線上諮詢</h3>
            <p>30分鐘免費諮詢，了解需求，服務內容與合作方式，初步確認合作方向。</p>
          </SectionCard>
          <SectionCard variant="number" number="2">
            <h3>初次面談及正式合約</h3>
            <p>溝通理財價值觀、合作方式，並明訂雙方權利義務以及保密條款。</p>
          </SectionCard>
          <SectionCard variant="number" number="3">
            <h3>財務面談</h3>
            <p>設定財務目標與風險責任，協助建立家庭財務報表並蒐集相關資料，進行風險承受度分析。</p>
          </SectionCard>
          <SectionCard variant="number" number="4">
            <h3>規劃報告</h3>
            <p>說明財務需求、分析結果，提供可執行的策略方案與效益比較。</p>
          </SectionCard>
          <SectionCard variant="number" number="5">
            <h3>方案執行</h3>
            <p>依目標協助執行：收支管理，保障規劃、資產規劃、稅務與其他需求。</p>
          </SectionCard>
          <SectionCard variant="number" number="6">
            <h3>定期檢視</h3>
            <p>追蹤財務目標達成率、投資組合表現與行為紀律，並依人生階段滾動式調整。</p>
          </SectionCard>
        </div>
      </div>
    </section>

    <!-- ▸ 預約諮詢 -->
    <section class="section consultation-section">
      <div class="container">
        <div class="consultation-box">
          <h2 class="section-title consultation-title">預約諮詢</h2>
          <p class="consultation-desc">若您想進一步了解財務規劃，我們提供 30 分鐘免費線上諮詢。協助釐清您的財務現況是否需要規劃，並說明諾昇的流程、服務內容與收費方式。</p>
          <p class="consultation-result"><strong>預期成果：</strong>您將帶走清楚的下一步方向，以及選擇最適合自己方案所需的完整資訊。</p>
          <div class="consultation-pricing">
            <div class="pricing-item">
              <h4>諮詢費</h4>
              <p class="pricing-amount">5,000 元 / 時</p>
              <p class="pricing-note">第一小時優惠 <span class="price-highlight">3,600 元</span><br />（半小時 <span class="price-highlight">1,800 元</span>）</p>
            </div>
            <div class="pricing-item">
              <h4>財務規劃</h4>
              <p class="pricing-note">依案件複雜程度（家庭人數、身份國籍、資產類型、特殊議題等）做個案報價。</p>
            </div>
          </div>
          <div class="consultation-cta">
            <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn consultation-btn">馬上預約諮詢</a>
          </div>
          <div class="consultation-disclaimer">
            <p style="font-weight: 600; margin-bottom: 8px;">請注意：</p>
            <ol style="padding-left: 1.2em; margin: 0;">
              <li>免費諮詢此為流程與方向說明，我們不會在 30 分鐘內提供個別財務問題的深入分析和解決方案建議。</li>
              <li>本服務提供財務建議，非屬投資或證券買賣建議。</li>
            </ol>
          </div>
        </div>
      </div>
    </section>

    {/* ▸ 免費諮詢 CTA */}
    {SHOW_CTA && (
    <section class="section section-primary cta-section">
      <div class="container">
        <div class="cta-layout">
          <div class="cta-content">
            <h2 class="section-title" style="color: var(--color-on-primary)">30 分鐘免費諮詢</h2>
            <p class="cta-desc">若您想進一步了解財務規劃，我們提供 30 分鐘免費線上諮詢。協助釐清您的財務現況是否需要規劃，並說明諾昇的流程、服務內容與收費方式。</p>
            <p class="cta-emphasis">您將帶走清楚的下一步方向，以及選擇最適合自己方案所需的完整資訊。</p>
            <div class="cta-buttons">
              <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn btn-accent btn-lg">LINE 預約諮詢</a>
              {SHOW_BOOKING && (
                <a href={base + "contact/"} class="btn btn-outline-light">預約免費諮詢</a>
              )}
            </div>
          </div>
          <div class="cta-notes">
            <div class="note-card">
              <h4>諮詢定位</h4>
              <p>僅提供流程說明與方向建議，不含個別深入分析</p>
            </div>
            <div class="note-card">
              <h4>內容限制</h4>
              <p>30 分鐘內不針對個人財務問題提供具體解決方案</p>
            </div>
            <div class="note-card">
              <h4>法律聲明</h4>
              <p>本服務屬財務顧問性質，非投資或證券買賣建議</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    )}

  </main>


</BaseLayout>

<style>
  /* ── SERVICE PHILOSOPHY ── */
  .service-philosophy {
    font-size: var(--fs-lg);
    line-height: 2;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── SERVICE ICON GRID ── */
  .service-icon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── INHERITANCE ── */
  .inheritance-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .inheritance-content p {
    line-height: 1.9;
  }
  .service-highlight { font-weight: 600; color: var(--color-accent); }
  .inheritance-illustration {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .inheritance-illustration svg {
    width: 100%;
    max-width: 400px;
    height: auto;
  }

  /* ── STEPS ── */
  .step-icon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── CONSULTATION ── */
  .consultation-section {
    background: var(--section-bg-highlight);
    border-top: 4px solid var(--color-accent);
  }
  .consultation-box {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .consultation-eyebrow {
    color: var(--color-accent);
  }
  .consultation-title {
    color: var(--color-primary);
  }
  .consultation-divider {
    border-color: var(--color-accent);
  }
  .consultation-desc {
    font-size: var(--fs-lg);
    line-height: 1.9;
