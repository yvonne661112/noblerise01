---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import PageHero from '../../components/PageHero.astro';
import { SHOW_BOOKING, CONTACT } from '../../data/siteConfig';
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="聯絡我們 | 諾昇理財規劃" description="聯絡諾昇理財規劃，預約財務規劃諮詢。Email: contact@noblerise.com.tw，LINE: @noblerise，地址: 106 台北市大安區復興南路一段222號2樓。" />
  
</head>
<body>
  <Header />

  <PageHero eyebrow="Contact" title="聯絡我們" />

  <main class="section">
    <div class="container">
      <div class={SHOW_BOOKING ? "grid-2" : ""} style="align-items:start;">
        {SHOW_BOOKING && (
        <div>
          <h2 class="section-title" style="margin-bottom:32px;">預約諮詢</h2>
          <form class="contact-form" name="contact" method="POST" action="/contact/">
            <div class="form-group">
              <label for="name">姓名 *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="phone">聯絡電話 *</label>
              <input type="tel" id="phone" name="phone" required />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="line">Line ID *</label>
              <input type="text" id="line" name="line" required />
            </div>
            <div class="form-group">
              <label for="topic">諮詢項目 *</label>
              <select id="topic" name="topic" required>
                <option value="">請選擇</option>
                <option value="trust">信託規劃</option>
                <option value="investment">投資理財</option>
                <option value="tax">傳承稅務</option>
                <option value="financial">財務規劃</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">內容概述 *</label>
              <textarea id="message" name="message" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">送出</button>
          </form>
        </div>
        )}

        <div>
          <h2 class="section-title" style="margin-bottom:32px;">聯絡資訊</h2>
          <div style="font-size:var(--fs-body);line-height:2.2;">
            <p><strong>公司</strong><br>{CONTACT.companyNameZh}<br>{CONTACT.companyNameEn}</p>
            <br />
            <p><strong>Email</strong><br><a href={`mailto:${CONTACT.email}`} style="color:var(--color-primary);">{CONTACT.email}</a></p>
            <br />
            <p><strong>LINE</strong><br><a href={CONTACT.lineUrl} target="_blank" rel="noopener" style="color:var(--color-primary);">{CONTACT.line}</a></p>
            <br />
            <p><strong>地址</strong><br>{CONTACT.address}</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>
