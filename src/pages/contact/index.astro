---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import PageHero from '../../components/PageHero.astro';
import { SHOW_BOOKING, CONTACT } from '../../data/siteConfig';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "聯絡我們 | 諾昇理財規劃",
  "description": "聯絡諾昇理財規劃，預約財務規劃諮詢。",
  "url": `${CONTACT.siteUrl}/contact/`,
  "mainEntity": {
    "@type": "Organization",
    "name": CONTACT.companyNameZh,
    "email": CONTACT.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": CONTACT.streetAddress,
      "addressLocality": CONTACT.addressLocality,
      "addressRegion": CONTACT.addressRegion,
      "postalCode": CONTACT.postalCode,
      "addressCountry": CONTACT.addressCountry,
    }
  }
};
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="聯絡我們 | 諾昇理財規劃" description={`聯絡諾昇理財規劃，預約財務規劃諮詢。Email: ${CONTACT.email}，LINE: ${CONTACT.line}，地址: ${CONTACT.address}。`} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header />

  <PageHero eyebrow="Contact" title="聯絡我們" />

  <div class="container" style="padding-top:40px;padding-bottom:0;">
    <img src={import.meta.env.BASE_URL + "images/聯絡我們.jpg"} alt="聯絡我們" loading="lazy" style="width:100%;max-width:380px;height:auto;display:block;" />
  </div>

  <main class="section">
    <div class="container">
      <div class={SHOW_BOOKING ? "grid-2" : ""} style="align-items:start;">
        {SHOW_BOOKING && (
        <div>
          <h2 class="section-title" style="margin-bottom:32px;">預約諮詢</h2>
          <form class="contact-form" name="contact" method="POST" action="/contact/">
            <div class="form-group">
              <label for="name">姓名 *</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="phone">聯絡電話 *</label>
              <input type="tel" id="phone" name="phone" required />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="line">Line ID *</label>
              <input type="text" id="line" name="line" required />
            </div>
            <div class="form-group">
              <label for="topic">諮詢項目 *</label>
              <select id="topic" name="topic" required>
                <option value="">請選擇</option>
                <option value="trust">信託規劃</option>
                <option value="investment">投資理財</option>
                <option value="tax">傳承稅務</option>
                <option value="financial">財務規劃</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">內容概述 *</label>
              <textarea id="message" name="message" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">送出</button>
          </form>
        </div>
        )}

        <div>
          <h2 class="section-title" style="margin-bottom:32px;">聯絡資訊</h2>
          <div style="font-size:var(--fs-body);line-height:2.2;">
            <p style="margin-bottom:1.5em;">
              <span style="display:inline-block;width:fit-content;max-width:100%;">
                <span style="display:block;text-align:justify;text-align-last:justify;">{CONTACT.companyNameZh}</span>
                <span style="display:block;text-align:justify;text-align-last:justify;">{CONTACT.companyNameEn}</span>
              </span>
            </p>
            <ul class="contact-info-list">
              <li>
                <span class="contact-icon">
                  <!-- Headset / LINE icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M12 2C7.03 2 3 6.03 3 11v3a3 3 0 0 0 3 3h1a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1H5v-1c0-3.87 3.13-7 7-7s7 3.13 7 7v1h-2a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h1c.34 0 .67-.06.97-.16A5.002 5.002 0 0 1 12 21H11a1 1 0 0 0 0 2h1a7 7 0 0 0 6.92-5.95A3 3 0 0 0 21 14v-3c0-4.97-4.03-9-9-9z"/>
                  </svg>
                </span>
                <span>LINE : <a href={CONTACT.lineUrl} target="_blank" rel="noopener" style="color:var(--color-accent);">{CONTACT.line}</a></span>
              </li>
              <li>
                <span class="contact-icon">
                  <!-- Envelope / Email icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.25-8 4.5-8-4.5V6l8 4.5L20 6v2.25z"/>
                  </svg>
                </span>
                <span><a href={`mailto:${CONTACT.email}`} style="color:var(--color-accent);">{CONTACT.email}</a></span>
              </li>
              <li>
                <span class="contact-icon">
                  <!-- ID card / Address icon -->
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM8 13H6v-2h2v2zm0-4H6V7h2v2zm10 4h-8v-2h8v2zm0-4h-8V7h8v2z"/>
                  </svg>
                </span>
                <span>{CONTACT.address}</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>
