---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import PageHero from '../../components/PageHero.astro';
import { SHOW_BOOKING, CONTACT } from '../../data/siteConfig';
import CompanyName from '../../components/CompanyName.astro';

const base = import.meta.env.BASE_URL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "聯絡我們 | 諾昇理財規劃",
  "description": "聯絡諾昇理財規劃，預約財務規劃諮詢。",
  "url": `${CONTACT.siteUrl}/contact/`,
  "mainEntity": {
    "@type": "Organization",
    "name": CONTACT.companyNameZh,
    "email": CONTACT.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": CONTACT.streetAddress,
      "addressLocality": CONTACT.addressLocality,
      "addressRegion": CONTACT.addressRegion,
      "postalCode": CONTACT.postalCode,
      "addressCountry": CONTACT.addressCountry,
    }
  }
};
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="聯絡我們 | 諾昇理財規劃" description={`聯絡諾昇理財規劃，預約財務規劃諮詢。Email: ${CONTACT.email}，LINE: ${CONTACT.line}，地址: ${CONTACT.address}。`} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header />

  <PageHero
    eyebrow="Contact"
    title="聯絡我們"
    description="有任何財務規劃問題，歡迎隨時與我們聯繫。"
  />

  <main class="section">
    <div class="container">
      {SHOW_BOOKING ? (
        <div class="grid-2 contact-grid">
          <div>
            <h2 class="section-title mb-32">預約諮詢</h2>
            <form class="contact-form" name="contact" method="POST" action="/contact/">
              <div class="form-group">
                <label for="name">姓名 *</label>
                <input type="text" id="name" name="name" required placeholder="您的姓名" />
              </div>
              <div class="form-group">
                <label for="phone">聯絡電話 *</label>
                <input type="tel" id="phone" name="phone" required placeholder="例：0912-345-678" />
              </div>
              <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="example@mail.com" />
              </div>
              <div class="form-group">
                <label for="line">Line ID *</label>
                <input type="text" id="line" name="line" required placeholder="您的 LINE ID" aria-describedby="line-hint" />
                <small id="line-hint" class="form-hint">請填寫您的個人 LINE ID，方便顧問與您聯繫</small>
              </div>
              <div class="form-group">
                <label for="topic">諮詢項目 *</label>
                <select id="topic" name="topic" required>
                  <option value="">請選擇諮詢項目</option>
                  <option value="trust">信託規劃</option>
                  <option value="investment">投資理財</option>
                  <option value="tax">傳承稅務</option>
                  <option value="financial">財務規劃</option>
                </select>
              </div>
              <div class="form-group">
                <label for="message">內容概述 *</label>
                <textarea id="message" name="message" required placeholder="請簡述您想諮詢的內容"></textarea>
              </div>
              <button type="submit" class="btn btn-primary">送出</button>
            </form>
          </div>
          <div>
            <h2 class="section-title mb-32">聯絡資訊</h2>
            <p class="contact-company"><CompanyName /></p>
          </div>
        </div>
      ) : (
        <div class="contact-layout">
          <div class="contact-image-col">
            <img src={base + "images/聯絡我們.jpg"} alt="聯絡我們" loading="lazy" />
          </div>
          <div class="contact-info-col">
            <h2 class="section-title mb-16">聯絡資訊</h2>
            <p class="contact-company">
              <CompanyName />
            </p>
            <ul class="contact-info-list">
              <li class="contact-li-top">
                <span class="contact-icon contact-icon-top">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M12 2C7.03 2 3 6.03 3 11v3a3 3 0 0 0 3 3h1a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1H5v-1c0-3.87 3.13-7 7-7s7 3.13 7 7v1h-2a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h1c.34 0 .67-.06.97-.16A5.002 5.002 0 0 1 12 21H11a1 1 0 0 0 0 2h1a7 7 0 0 0 6.92-5.95A3 3 0 0 0 21 14v-3c0-4.97-4.03-9-9-9z"/>
                  </svg>
                </span>
                <span>
                  LINE : <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="contact-accent-link">{CONTACT.line}</a>
                  <br />
                  <img src={base + "images/noblerise_line_at.png"} alt="諾昇理財 LINE QR Code" loading="lazy" class="contact-qr" />
                </span>
              </li>
              <li>
                <span class="contact-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.25-8 4.5-8-4.5V6l8 4.5L20 6v2.25z"/>
                  </svg>
                </span>
                <span><a href={`mailto:${CONTACT.email}`} class="contact-accent-link">{CONTACT.email}</a></span>
              </li>
              <li>
                <span class="contact-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
                    <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM8 13H6v-2h2v2zm0-4H6V7h2v2zm10 4h-8v-2h8v2zm0-4h-8V7h8v2z"/>
                  </svg>
                </span>
                <span>{CONTACT.address}</span>
              </li>
            </ul>
            <div class="mt-32">
              <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn btn-line">LINE 聯絡我們</a>
            </div>
            <div class="mt-32 contact-map-wrap">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3614.8488013209458!2d121.54089257480517!3d25.039204738083015!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3442abd127faaaab%3A0xaa3abe32ac4257c7!2zMTA26Ie65YyX5biC5aSn5a6J5Y2A5b6p6IiI5Y2X6Lev5LiA5q61MjIy6JmfMuaokw!5e0!3m2!1szh-TW!2stw!4v1774483760498!5m2!1szh-TW!2stw"
                class="contact-map"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="諾昇理財規劃顧問地圖"
              ></iframe>
            </div>
          </div>
        </div>
      )}
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  /* ── LAYOUT ── */
  .contact-grid { align-items: start; }
  .contact-company { margin-bottom: 1.5em; font-size: var(--fs-body); }
  .contact-info-col { }
  .contact-li-top { align-items: flex-start; }
  .contact-icon-top { margin-top: 4px; }
  .contact-accent-link { color: var(--color-accent); font-weight: 500; }
  .contact-qr { width: 120px; height: auto; margin-top: 8px; display: block; }
  .contact-map-wrap { aspect-ratio: 16 / 9; border-radius: var(--card-radius); overflow: hidden; }
  .contact-map { border: 0; display: block; width: 100%; height: 100%; }
</style>
