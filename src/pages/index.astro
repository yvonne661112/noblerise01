---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BlogList from '../components/BlogList.astro';
import { getCollection } from 'astro:content';
import { CONTACT, SHOW_CTA } from '../data/siteConfig';
import { sortPostsByDate, transformPost } from '../utils/post';

const base = import.meta.env.BASE_URL;
const latestPosts = sortPostsByDate(await getCollection('blog')).slice(0, 3);
const latestPostViews = latestPosts.map(p => transformPost(p, base));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": CONTACT.companyNameZh,
    "url": CONTACT.siteUrl,
    "logo": `${CONTACT.siteUrl}/wp-content/uploads/2026/01/Nobleriselong1-scaled.png`,
    "email": CONTACT.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": CONTACT.streetAddress,
      "addressLocality": CONTACT.addressLocality,
      "addressRegion": CONTACT.addressRegion,
      "postalCode": CONTACT.postalCode,
      "addressCountry": CONTACT.addressCountry,
    },
    "areaServed": { "@type": "Country", "name": "TW" },
    "serviceType": ["財務規劃", "退休規劃", "資產信託", "稅務規劃", "保險規劃", "投資顧問"],
    "founder": {
      "@type": "Person",
      "name": "張惠芳",
      "jobTitle": "CFP® 國際認證高級理財規劃顧問"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "諾昇理財規劃",
    "url": CONTACT.siteUrl,
  },
  // 客戶見證 Review Schema
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "FinancialService", "name": CONTACT.companyNameZh },
    "author": { "@type": "Person", "name": "張先生" },
    "reviewBody": "「55歲退休能實現嗎？」惠芳CFP以專業財務顧問角度，科學量化精算一生的現金流，從退休資金、稅務、到資產信託規劃與實際執行，每一步都讓我更踏實，不只做規劃，更定期提醒與追蹤進度，讓我能專心衝刺事業，不再為未來焦慮，完成規劃後，我對人生財務藍圖更加安心！"
  },
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "FinancialService", "name": CONTACT.companyNameZh },
    "author": { "@type": "Person", "name": "陳小姐" },
    "reviewBody": "我常思考：「保險買這麼多，真的都需要嗎？」惠芳CFP以獨立理財規劃顧問第三方角色，全面盤點保單與資產，揪出多餘的保障與不當理財商品，重新調整收支與現金流，繳更少保費，保障卻差不多，大幅降低保險支出，資產負債表一目了然，心更安定，讓我體會到：「找對顧問，是最聰明的省錢方式！」"
  },
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "FinancialService", "name": CONTACT.companyNameZh },
    "author": { "@type": "Person", "name": "王先生" },
    "reviewBody": "我是財務投資小白，在惠芳CFP指導下，從開戶到投資執行與收支掌控逐步建立，每月養成紀錄習慣，重新確立理財目標，一步步打造理想生活藍圖與財務秩序。我也開始學習用AI自學新知，提升專業能力與收入，財務壓力漸漸減輕，不再焦慮也不盲從，逐步邁向我的財務幸福。"
  }
];
---
<BaseLayout
  title="諾昇理財規劃｜張惠芳 CFP® 獨立理財顧問｜財務幸福"
  description="諾昇以財務幸福為核心，由 CFP® 張惠芳領軍，提供中立、專業、以客戶利益優先的獨立財務規劃服務，涵蓋投資、保險、退休、信託、稅務規劃。"
>
  {jsonLd.map(ld => (
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
  ))}

  <!-- ▸ HERO -->
  <PageHero
    title="諾昇理財規劃<br/><span class='hero-sub'>成為您人生的底氣<br/>陪您走向財務幸福</span>"
    large
  />


  <!-- ▸ ACT 1：引起共鳴 + 解決方案 -->
  <section class="section">
    <div class="container">
      <div class="empathy-block text-center mb-48 reveal">
        <h2 class="section-title">面對理財，您是否也有這些疑問？</h2>
        <p class="empathy-text">「努力存錢卻不知道夠不夠？」<br/>「買了一堆保險不知道有沒有重複或永遠買不夠？」<br/>「想規劃退休，卻不知道從何開始？」</p>
        <p class="empathy-answer">您不需要一個人面對，諾昇不是銀行、不是保險公司，<br/>我們是站在您身邊的獨立理財規劃夥伴。</p>
      </div>
      <div class="grid-3 values-grid reveal">
        <div class="value-card">
          <div class="value-icon">
            <img src={base + "images/真正獨立.png"} alt="真正獨立 不賣產品" loading="lazy" class="value-icon-img" />
          </div>
          <h3>真正獨立，不賣產品</h3>
          <p>不受金融機構 KPI 影響，完全站在客戶立場，只給最適合您的建議。</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <img src={base + "images/專業規劃客製方案.png"} alt="專業規劃 客製方案" loading="lazy" class="value-icon-img" />
          </div>
          <h3>專業規劃，客製方案</h3>
          <p>依國際理財規劃 FPSB 流程量身打造，採規劃收費，確保建議客觀純粹。</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <img src={base + "images/全程陪伴規劃.png"} alt="全程陪伴 規劃＋執行" loading="lazy" class="value-icon-img" />
          </div>
          <h3>全程陪伴，規劃到執行</h3>
          <p>不只給建議，更協助落地執行。隨人生變化調整，讓財務規劃看得見成果。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ ACT 2：信任建立 — 顧問介紹 -->
  <section class="section">
    <div class="container">
      <div class="advisor-intro reveal">
        <div class="advisor-photo-wrap">
          <img src={base + "images/yvonneCFP.jpeg"} alt="張惠芳 CFP® 首席理財規劃顧問" width="400" height="400" loading="lazy" class="advisor-photo" />
        </div>
        <div class="advisor-content">
          <span class="section-eyebrow">Chief Planning Advisor</span>
          <h2 class="section-title">張惠芳 CFP®</h2>
          <p class="advisor-role">諾昇理財首席規劃顧問 ／ 執行長</p>
          <hr class="section-divider" />
          <p>憑藉 20 年金融實務經驗，張惠芳 CFP® 始終堅持「不賣產品，專注規劃」的獨立理財規劃顧問角色。我們深信：真正的財務安全，不在於盲目追求高報酬，而是要讓您的每一分錢都能準確達成人生目標。理財不該是冰冷的數字賽跑，而是連結您嚮往的「財務幸福人生」。</p>
          <ul class="credential-list mt-24">
            <li class="credential-badge"><a href="https://www.fpat.org.tw/LecturerResume/SearchPage/5009" target="_blank" rel="noopener nofollow noreferrer">CFP® 國際認證高級理財規劃顧問</a></li>
            <li class="credential-badge">RFA 退休理財顧問</li>
            <li class="credential-badge">FChFP 特許財務規劃師</li>
            <li class="credential-badge">家族信託規劃顧問師</li>
          </ul>
          <div class="mt-32">
            <a href={base + "about/"} class="btn btn-primary">了解更多</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ ACT 3：服務項目 -->
  <section class="section section-subtle">
    <div class="container">
      <div class="text-center mb-48">
        <span class="section-eyebrow">Services</span>
        <h2 class="section-title">全方位財務規劃服務</h2>
        <p class="section-subtitle" style="margin-bottom: 0; max-width: 640px; margin-left: auto; margin-right: auto;">從日常收支到財富傳承，諾昇為您的每個人生階段提供專業規劃。</p>
      </div>
      <div class="service-grid reveal">
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
              <path d="M5 9.2h3V19H5V9.2zm5.6-4.2h2.8v14h-2.8V5zm5.6 8h2.8v6h-2.8v-6z"/>
            </svg>
          </div>
          <h3>收支管理與財務盤點</h3>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
              <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
            </svg>
          </div>
          <h3>保險保障規劃</h3>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
              <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
            </svg>
          </div>
          <h3>教育與家庭規劃</h3>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
          </div>
          <h3>房產與重大資產決策</h3>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
              <path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/>
            </svg>
          </div>
          <h3>退休與投資策略</h3>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="40" height="40" aria-hidden="true">
              <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
            </svg>
          </div>
          <h3>傳承與高齡照護</h3>
        </a>
      </div>
      <div class="text-center mt-48">
        <a href={base + "service/"} class="btn btn-primary">查看完整服務</a>
      </div>
    </div>
  </section>

  <!-- ▸ ACT 4：社會證明 — 客戶見證 -->
  <section class="section section-testimonial">
    <div class="container">
      <div class="text-center mb-48">
        <h2 class="section-title">他們的故事，也許就是您的下一步</h2>
      </div>
      <div class="testimonials reveal">
        <div class="testimonial testimonial--light testimonial--featured">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <p class="testimonial-text">「55歲退休能實現嗎？」惠芳CFP以專業財務顧問角度，科學量化精算一生的現金流，從退休資金、稅務、到資產信託規劃與實際執行，每一步都讓我更踏實，不只做規劃，更定期提醒與追蹤進度，讓我能專心衝刺事業，不再為未來焦慮，完成規劃後，我對人生財務藍圖更加安心！</p>
          <div class="testimonial-author">
            <img src={base + "images/home-customer2.jpg"} alt="張先生" width="72" height="72" loading="lazy" class="testimonial-avatar" />
            <p class="testimonial-label">科技業主管／張先生</p>
          </div>
        </div>
        <div class="testimonial testimonial--light testimonial--featured">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <p class="testimonial-text">我常思考：「保險買這麼多，真的都需要嗎？」惠芳CFP以獨立理財規劃顧問第三方角色，全面盤點保單與資產，揪出多餘的保障與不當理財商品，重新調整收支與現金流，繳更少保費，保障卻差不多，大幅降低保險支出，資產負債表一目了然，心更安定，讓我體會到：「找對顧問，是最聰明的省錢方式！」</p>
          <div class="testimonial-author">
            <img src={base + "images/home-customer3.jpg"} alt="陳小姐" width="72" height="72" loading="lazy" class="testimonial-avatar" />
            <p class="testimonial-label">退休人士／陳小姐</p>
          </div>
        </div>
        <div class="testimonial testimonial--light testimonial--featured">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <p class="testimonial-text">我是財務投資小白，在惠芳CFP指導下，從開戶到投資執行與收支掌控逐步建立，每月養成紀錄習慣，重新確立理財目標，一步步打造理想生活藍圖與財務秩序。我也開始學習用AI自學新知，提升專業能力與收入，財務壓力漸漸減輕，不再焦慮也不盲從，逐步邁向我的財務幸福。</p>
          <div class="testimonial-author">
            <img src={base + "images/home-customer1.jpg"} alt="李先生" width="72" height="72" loading="lazy" class="testimonial-avatar" />
            <p class="testimonial-label">工程監工／李先生</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ 媒體採訪 -->
  <section class="section">
    <div class="container">
      <div class="media-section reveal">
        <div class="media-left">
          <span class="section-eyebrow">Media Coverage</span>
          <h2 class="section-title">媒體採訪與專欄</h2>
          <hr class="section-divider" />
          <ul class="media-list">
            <li><strong>TVBS 十點不一樣</strong>：<a href="https://youtu.be/_XeCIzm6pOU" target="_blank" rel="noopener nofollow noreferrer">社會保障支出破2.6兆! 平均每人11.5萬 為何民眾喊「無感」?</a></li>
            <li><strong>TVBS 十點不一樣</strong>：<a href="https://youtu.be/KdxAo-9BpdI?si=QiA8Up1xF-uInhRQ&t=180" target="_blank" rel="noopener nofollow noreferrer">勞保年金差距曝光!電力業月領3.3萬 餐旅業僅1.7萬入不敷出</a></li>
            <li><strong>天下雜誌</strong>：<a href="https://www.cw.com.tw/article/5136867" target="_blank" rel="noopener nofollow noreferrer">台灣家庭存錢調查：一年存多少錢才正常？</a></li>
            <li><strong>今周刊</strong>：<a href="https://www.businesstoday.com.tw/article/category/183035/post/202510270037/" target="_blank" rel="noopener nofollow noreferrer">薇閣、康橋、復興...11所私校學費一次看！每年100萬值得嗎？專家教你如何籌出孩子教育費、還能兼存退休金</a></li>
            <li><strong>橘世代</strong>：<a href="https://orange.udn.com/orange/story/121197/9136896" target="_blank" rel="noopener nofollow noreferrer">癌症醫療燒掉的錢好驚人！一次看懂癌症險買多少、怎麼買及常見盲點</a></li>
            <li><strong>FPAT Podcast</strong>：<a href="https://solink.soundon.fm/episode/5c950785-667b-4cd3-bc5a-2d108321a0c0" target="_blank" rel="noopener nofollow noreferrer">投資不是賺更多，是規劃更好-優雅轉身CFP®張惠芳</a></li>
            <li><strong>FPAT 2022理財規劃書競賽活動</strong>：<a href="https://www.youtube.com/watch?v=ykfA1qhsj1w" target="_blank" rel="noopener nofollow noreferrer">榮獲最佳顧問獎</a></li>
          </ul>
        </div>
        <div class="media-right">
          <a href="https://www.youtube.com/watch?v=QktyMzy--68" target="_blank" rel="noopener nofollow noreferrer" class="media-video-link">
            <img src={base + "images/tvbs-thumbnail2.png"} alt="TVBS 十點不一樣專訪" width="510" height="280" loading="lazy" />
            <span class="media-play-btn" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none" width="48" height="48"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.55)"/><path d="M19 16l14 8-14 8V16z" fill="#fff"/></svg>
            </span>
          </a>
          <a href="https://youtu.be/_XeCIzm6pOU" target="_blank" rel="noopener nofollow noreferrer" class="media-video-link">
            <img src={base + "images/tvbs-social-insurance.jpg"} alt="TVBS 社會保險覆蓋" width="510" height="280" loading="lazy" />
            <span class="media-play-btn" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none" width="48" height="48"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.55)"/><path d="M19 16l14 8-14 8V16z" fill="#fff"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ 最新文章 -->
  <section class="section section-subtle">
    <div class="container">
      <div class="text-center mb-48">
        <span class="section-eyebrow">Latest Articles</span>
        <h2 class="section-title">理財新知</h2>
        <p class="section-subtitle" style="margin-bottom: 0; max-width: 560px; margin-left: auto; margin-right: auto;">專業觀點、實用知識，幫助您做出更好的財務決策。</p>
      </div>
      <BlogList posts={latestPostViews} showCatBar={false} />
      <div class="text-center mt-48">
        <a href={base + "blog/"} class="btn btn-primary">查看所有文章</a>
      </div>
    </div>
  </section>

  {/* ▸ CTA */}
  {SHOW_CTA && (
  <section class="section section-primary cta-section">
    <div class="container text-center">
      <h2 class="section-title" style="color: var(--color-on-primary)">準備好開始您的財務規劃了嗎？</h2>
      <p style="color: rgba(255,255,255,0.8); font-size: var(--fs-lg); max-width: 560px; margin: 0 auto 36px;">我們提供 30 分鐘免費線上諮詢，協助釐清您的財務現況與下一步方向。</p>
      <div class="cta-buttons">
        <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn btn-accent btn-lg">LINE 預約諮詢</a>
        <a href={base + "contact/"} class="btn btn-outline-light btn-lg">聯絡我們</a>
      </div>
    </div>
  </section>
  )}


</BaseLayout>

<style>
  /* ── HERO ── */
  :global(.page-hero--large) {
    min-height: auto !important;
    padding-top: 48px !important;
    padding-bottom: 40px !important;
  }
  :global(.hero-sub) {
    display: block;
    font-size: clamp(20px, 3vw, 30px);
    font-weight: 400;
    margin-top: 8px;
    line-height: 1.5;
  }
  /* ── EMPATHY BLOCK ── */
  .empathy-text {
    font-family: var(--font-heading);
    font-size: clamp(18px, 2.5vw, 24px);
