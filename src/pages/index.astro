---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BlogList from '../components/BlogList.astro';
import { getCollection } from 'astro:content';
import { CONTACT, SHOW_CTA } from '../data/siteConfig';
import { sortPostsByDate, transformPost } from '../utils/post';

const base = import.meta.env.BASE_URL;
const latestPosts = sortPostsByDate(await getCollection('blog')).slice(0, 6);
const latestPostViews = latestPosts.map(p => transformPost(p, base));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": CONTACT.companyNameZh,
    "url": CONTACT.siteUrl,
    "logo": `${CONTACT.siteUrl}/wp-content/uploads/2026/01/Nobleriselong1-scaled.png`,
    "email": CONTACT.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": CONTACT.streetAddress,
      "addressLocality": CONTACT.addressLocality,
      "addressRegion": CONTACT.addressRegion,
      "postalCode": CONTACT.postalCode,
      "addressCountry": CONTACT.addressCountry,
    },
    "areaServed": { "@type": "Country", "name": "TW" },
    "serviceType": ["財務規劃", "退休規劃", "資產信託", "稅務規劃", "保險規劃", "投資顧問"],
    "founder": {
      "@type": "Person",
      "name": "張惠芳",
      "jobTitle": "CFP® 國際認證高級理財規劃顧問"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "諾昇理財規劃",
    "url": CONTACT.siteUrl,
  },
  // 客戶見證 Review Schema
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "FinancialService", "name": CONTACT.companyNameZh },
    "author": { "@type": "Person", "name": "張先生" },
    "reviewBody": "55 歲退休能實現嗎？惠芳 CFP 以科學方式精算一生的現金流，從退休資金、稅務到資產信託規劃，每一步都讓我更踏實。完成規劃後，我對人生財務藍圖更加安心！"
  },
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "FinancialService", "name": CONTACT.companyNameZh },
    "author": { "@type": "Person", "name": "陳小姐" },
    "reviewBody": "惠芳 CFP 以獨立第三方角色全面盤點保單，揪出多餘保障與不當理財商品，大幅降低保險支出，資產負債表一目了然。找對顧問，是最聰明的省錢方式！"
  },
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": { "@type": "FinancialService", "name": CONTACT.companyNameZh },
    "author": { "@type": "Person", "name": "王先生" },
    "reviewBody": "在惠芳 CFP 指導下，從開戶到投資執行、收支掌控，我一步步建立理財秩序。財務壓力漸漸減輕，不再焦慮也不盲從，逐步邁向我的財務幸福。"
  }
];
---
<BaseLayout
  title="諾昇理財規劃｜張惠芳 CFP® 獨立理財顧問｜財務幸福"
  description="諾昇以財務幸福為核心，由 CFP® 張惠芳領軍，提供中立、專業、以客戶利益優先的獨立財務規劃服務，涵蓋投資、保險、退休、信託、稅務規劃。"
>
  {jsonLd.map(ld => (
    <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />
  ))}

  <!-- ▸ HERO -->
  <PageHero
    eyebrow="Independent Financial Planning"
    title="讓財務規劃<br/>成為你人生的底氣"
    description="不推銷、不賣產品 — 只為你的財務幸福而規劃"
    backgroundImage="images/hero-home.jpg"
    large
  >
    <a href={base + "service/"} class="btn btn-accent btn-lg">了解我們的服務</a>
    <a href={base + "about/"} class="btn btn-outline-light btn-lg">認識諾昇</a>
  </PageHero>

  <!-- ▸ STATS BAR -->
  <div class="stat-bar" id="stat-bar">
    <div class="stat-item">
      <span class="stat-number" data-count="20" data-suffix="+">0</span>
      <span class="stat-label">年金融實務經驗</span>
    </div>
    <div class="stat-item">
      <span class="stat-number">CFP®</span>
      <span class="stat-label">國際認證理財規劃顧問</span>
    </div>
    <div class="stat-item">
      <span class="stat-number" data-count="4">0</span>
      <span class="stat-label">項國際專業認證</span>
    </div>
    <div class="stat-item">
      <span class="stat-number" data-count="6">0</span>
      <span class="stat-label">大媒體專欄作家</span>
    </div>
  </div>

  <script>
    const bar = document.getElementById('stat-bar');
    if (bar) {
      const counters = bar.querySelectorAll('[data-count]');
      let animated = false;
      const animate = () => {
        if (animated) return;
        animated = true;
        counters.forEach(el => {
          const target = parseInt(el.getAttribute('data-count')!, 10);
          const suffix = el.getAttribute('data-suffix') || '';
          const duration = 1200;
          const start = performance.now();
          const tick = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(eased * target) + suffix;
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      };
      const obs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) { animate(); obs.disconnect(); }
      }, { threshold: 0.5 });
      obs.observe(bar);
    }
  </script>

  <!-- ▸ ACT 1：引起共鳴 + 解決方案 -->
  <section class="section">
    <div class="container">
      <div class="empathy-block text-center mb-48 reveal">
        <span class="section-eyebrow">The Challenge</span>
        <h2 class="section-title">面對理財，你是否也有這些疑問？</h2>
        <p class="empathy-text">「努力存錢卻不知道夠不夠？」「買了一堆保險但真的有保到？」「想規劃退休，卻不知道從何開始？」</p>
        <p class="empathy-answer">你不需要一個人面對。諾昇不是銀行、不是保險公司 — 我們是站在你身邊的獨立理財規劃夥伴。</p>
      </div>
      <div class="grid-3 values-grid reveal">
        <div class="value-card">
          <div class="value-icon">
            <img src={base + "images/真正獨立.png"} alt="真正獨立 不賣產品" loading="lazy" class="value-icon-img" />
          </div>
          <h3>真正獨立，不賣產品</h3>
          <p>不受金融機構 KPI 影響，完全站在客戶立場，只給最適合你的建議。</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <img src={base + "images/專業規劃客製方案.png"} alt="專業規劃 客製方案" loading="lazy" class="value-icon-img" />
          </div>
          <h3>專業規劃，客製方案</h3>
          <p>依國際理財規劃 FPSB 流程量身打造，採規劃收費，確保建議客觀純粹。</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <img src={base + "images/全程陪伴規劃.png"} alt="全程陪伴 規劃＋執行" loading="lazy" class="value-icon-img" />
          </div>
          <h3>全程陪伴，規劃到執行</h3>
          <p>不只給建議，更協助落地執行。隨人生變化調整，讓財務規劃看得見成果。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ ACT 2：信任建立 — 顧問介紹 -->
  <section class="section section-subtle">
    <div class="container">
      <div class="advisor-intro reveal">
        <div class="advisor-photo-wrap">
          <img src={base + "images/yvonneCFP.jpeg"} alt="張惠芳 CFP® 首席理財規劃顧問" width="400" height="400" loading="lazy" class="advisor-photo" />
        </div>
        <div class="advisor-content">
          <span class="section-eyebrow">Chief Planning Advisor</span>
          <h2 class="section-title">張惠芳 CFP®</h2>
          <p class="advisor-role">諾昇理財首席規劃顧問 ／ 執行長</p>
          <hr class="section-divider" />
          <p>以 20 年金融實務經驗，張惠芳建立了「不賣產品、只做規劃」的獨立顧問服務模式。她相信：真正的財務安全不是追求高報酬，而是讓每一分錢都為你的人生目標服務。</p>
          <ul class="credential-list mt-24">
            <li class="credential-badge">CFP® 國際認證</li>
            <li class="credential-badge">RFA 退休理財顧問</li>
            <li class="credential-badge">FChFP 特許財務規劃師</li>
            <li class="credential-badge">家族信託規劃顧問師</li>
          </ul>
          <div class="mt-32">
            <a href={base + "about/"} class="btn btn-primary">了解更多</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ ACT 3：服務項目 -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-48">
        <span class="section-eyebrow">Services</span>
        <h2 class="section-title">全方位財務規劃服務</h2>
        <p class="section-subtitle" style="margin-bottom: 0; max-width: 640px; margin-left: auto; margin-right: auto;">從日常收支到財富傳承，諾昇為你的每個人生階段提供專業規劃。</p>
      </div>
      <div class="service-grid reveal">
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-wrap">
            <img src={base + "images/home-service-items-01.png"} alt="收支管理與財務盤點" loading="lazy" />
          </div>
          <h3>收支管理與財務盤點</h3>
          <p>釐清收支全貌，建立可執行的財務架構。</p>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-wrap">
            <img src={base + "images/home-service-items-02.png"} alt="保險保障規劃" loading="lazy" />
          </div>
          <h3>保險保障規劃</h3>
          <p>以第三方角度審視保單，花更少、保更好。</p>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-wrap">
            <img src={base + "images/home-service-items-03.png"} alt="教育與家庭目標規劃" loading="lazy" />
          </div>
          <h3>教育與家庭規劃</h3>
          <p>為孩子的教育金、家庭里程碑做好財務準備。</p>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-wrap">
            <img src={base + "images/home-service-items-04.png"} alt="房產與重大資產決策" loading="lazy" />
          </div>
          <h3>房產與重大資產決策</h3>
          <p>理性評估買房時機，做出聰明的資產配置。</p>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-wrap">
            <img src={base + "images/home-service-items-05.png"} alt="退休與投資積累策略" loading="lazy" />
          </div>
          <h3>退休與投資策略</h3>
          <p>科學規劃退休金，讓未來的自己無後顧之憂。</p>
        </a>
        <a href={base + "service/"} class="service-item">
          <div class="service-icon-wrap">
            <img src={base + "images/home-service-items-06.png"} alt="傳承與高齡照護規劃" loading="lazy" />
          </div>
          <h3>傳承與高齡照護</h3>
          <p>信託、稅務、傳承一站規劃，守護家族財富。</p>
        </a>
      </div>
      <div class="text-center mt-48">
        <a href={base + "service/"} class="btn btn-primary">查看完整服務</a>
      </div>
    </div>
  </section>

  <!-- ▸ ACT 4：社會證明 — 客戶見證 -->
  <section class="section section-dark">
    <div class="container">
      <div class="text-center mb-48">
        <span class="section-eyebrow">Testimonials</span>
        <h2 class="section-title">他們的故事，也許就是你的下一步</h2>
      </div>
      <div class="testimonials reveal">
        <div class="testimonial testimonial--dark testimonial--featured">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <img src={base + "images/home-customer2.jpg"} alt="張先生" width="72" height="72" loading="lazy" class="testimonial-avatar" />
          <p class="testimonial-text">「55 歲退休能實現嗎？」惠芳 CFP 以科學方式精算一生的現金流，從退休資金、稅務到資產信託規劃，每一步都讓我更踏實。完成規劃後，我對人生財務藍圖更加安心！</p>
          <p class="testimonial-name">張先生</p>
          <p class="testimonial-role">科技業主管</p>
        </div>
        <div class="testimonial testimonial--dark testimonial--featured">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <img src={base + "images/home-customer3.jpg"} alt="陳小姐" width="72" height="72" loading="lazy" class="testimonial-avatar" />
          <p class="testimonial-text">惠芳 CFP 以獨立第三方角色全面盤點保單，揪出多餘保障與不當理財商品，大幅降低保險支出，資產負債表一目了然。找對顧問，是最聰明的省錢方式！</p>
          <p class="testimonial-name">陳小姐</p>
          <p class="testimonial-role">退休人士</p>
        </div>
        <div class="testimonial testimonial--dark testimonial--featured">
          <div class="testimonial-quote" aria-hidden="true">"</div>
          <img src={base + "images/home-customer1.jpg"} alt="王先生" width="72" height="72" loading="lazy" class="testimonial-avatar" />
          <p class="testimonial-text">在惠芳 CFP 指導下，從開戶到投資執行、收支掌控，我一步步建立理財秩序。財務壓力漸漸減輕，不再焦慮也不盲從，逐步邁向我的財務幸福。</p>
          <p class="testimonial-name">王先生</p>
          <p class="testimonial-role">工程監工</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ 媒體採訪 -->
  <section class="section">
    <div class="container">
      <div class="media-section reveal">
        <div class="media-left">
          <span class="section-eyebrow">Media Coverage</span>
          <h2 class="section-title">媒體採訪與專欄</h2>
          <hr class="section-divider" />
          <ul class="media-list">
            <li><strong>TVBS 十點不一樣</strong>：<a href="https://youtu.be/_XeCIzm6pOU" target="_blank" rel="noopener nofollow noreferrer">社會保障支出破 2.6 兆</a></li>
            <li><strong>TVBS 十點不一樣</strong>：<a href="https://youtu.be/KdxAo-9BpdI?si=QiA8Up1xF-uInhRQ&t=180" target="_blank" rel="noopener nofollow noreferrer">勞保年金差距曝光</a></li>
            <li><strong>TVBS 十點不一樣</strong>：<a href="https://www.youtube.com/watch?v=QktyMzy--68" target="_blank" rel="noopener nofollow noreferrer">窮到只剩下錢？貧窮妄想</a></li>
            <li><strong>天下雜誌</strong>：<a href="https://www.cw.com.tw/article/5136867" target="_blank" rel="noopener nofollow noreferrer">一年存多少才正常？</a></li>
            <li><strong>今周刊</strong>：<a href="https://www.businesstoday.com.tw/article/category/183035/post/202510270037/" target="_blank" rel="noopener nofollow noreferrer">11 所私校學費一次看</a></li>
            <li><strong>橘世代</strong>：<a href="https://orange.udn.com/orange/story/121197/9136896" target="_blank" rel="noopener nofollow noreferrer">癌症醫療花費與癌症險</a></li>
            <li><strong>FPAT Podcast</strong>：<a href="https://solink.soundon.fm/episode/5c950785-667b-4cd3-bc5a-2d108321a0c0" target="_blank" rel="noopener nofollow noreferrer">全方位理財師 CFP® 張惠芳</a></li>
          </ul>
        </div>
        <div class="media-right">
          <a href="https://www.youtube.com/watch?v=QktyMzy--68" target="_blank" rel="noopener nofollow noreferrer" class="media-video-link">
            <img src={base + "images/tvbs-thumbnail2.png"} alt="TVBS 十點不一樣專訪" width="510" height="280" loading="lazy" />
            <span class="media-play-btn" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none" width="48" height="48"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.55)"/><path d="M19 16l14 8-14 8V16z" fill="#fff"/></svg>
            </span>
          </a>
          <a href="https://youtu.be/_XeCIzm6pOU" target="_blank" rel="noopener nofollow noreferrer" class="media-video-link">
            <img src={base + "images/社會保障支出破2.6兆.png"} alt="社會保障支出破 2.6 兆" width="510" height="280" loading="lazy" />
            <span class="media-play-btn" aria-hidden="true">
              <svg viewBox="0 0 48 48" fill="none" width="48" height="48"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.55)"/><path d="M19 16l14 8-14 8V16z" fill="#fff"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ▸ 最新文章 -->
  <section class="section section-subtle">
    <div class="container">
      <div class="text-center mb-48">
        <span class="section-eyebrow">Latest Articles</span>
        <h2 class="section-title">理財新知</h2>
        <p class="section-subtitle" style="margin-bottom: 0; max-width: 560px; margin-left: auto; margin-right: auto;">專業觀點、實用知識，幫助你做出更好的財務決策。</p>
      </div>
      <BlogList posts={latestPostViews} showCatBar={false} />
      <div class="text-center mt-48">
        <a href={base + "blog/"} class="btn btn-primary">查看所有文章</a>
      </div>
    </div>
  </section>

  {/* ▸ CTA */}
  {SHOW_CTA && (
  <section class="section section-primary cta-section">
    <div class="container text-center">
      <h2 class="section-title" style="color: var(--color-on-primary)">準備好開始你的財務規劃了嗎？</h2>
      <p style="color: rgba(255,255,255,0.8); font-size: var(--fs-lg); max-width: 560px; margin: 0 auto 36px;">我們提供 30 分鐘免費線上諮詢，協助釐清你的財務現況與下一步方向。</p>
      <div class="cta-buttons">
        <a href={CONTACT.lineUrl} target="_blank" rel="noopener" class="btn btn-accent btn-lg">LINE 預約諮詢</a>
        <a href={base + "contact/"} class="btn btn-outline-light btn-lg">聯絡我們</a>
      </div>
    </div>
  </section>
  )}


</BaseLayout>

<style>
  /* ── EMPATHY BLOCK ── */
  .empathy-text {
    font-family: var(--font-heading);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: var(--heading-weight);
    color: var(--color-accent);
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto 16px;
  }
  .empathy-answer {
    font-size: var(--fs-lg);
    color: var(--color-text-mid);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* ── ADVISOR INTRO ── */
  .advisor-intro {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 64px;
    align-items: center;
  }
  .advisor-photo-wrap {
    position: relative;
  }
  .advisor-photo {
    width: 100%;
    height: auto;
    display: block;
  }
  .advisor-content { }
  .advisor-role {
    font-size: var(--fs-md);
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 4px;
  }

  /* ── VALUES ── */
  .values-grid { }
  .value-card {
    background: var(--color-white);
    border-radius: var(--card-radius);
    padding: 36px 28px;
    text-align: center;
    border: 1px solid var(--color-border);
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .value-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-4px);
  }
  .value-card .value-icon { margin-bottom: 20px; }
  .value-card h3 {
    font-family: var(--font-heading);
    font-size: var(--fs-xl);
    font-weight: var(--heading-weight);
    color: var(--color-primary);
    margin-bottom: 12px;
