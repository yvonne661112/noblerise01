---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
import { categoryLabels } from '../data/categories';
import { publisher } from '../utils/jsonld';
import { getAssetPath } from '../utils/assets';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.numericSlug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, image, categories } = post.data;

const formattedDate = new Date(date).toLocaleDateString('zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric'
});

// 閱讀時間估算（中文約 500 字/分鐘）
const body = post.body || '';
const charCount = body.replace(/\s/g, '').length;
const readingTime = Math.max(1, Math.ceil(charCount / 500));

const mainCategory = categories?.find(c => c !== 'blog') ?? 'blog';
const categoryLabel = categoryLabels[mainCategory] ?? '理財新知';
const categoryUrl = mainCategory === 'blog' ? `${import.meta.env.BASE_URL}blog/` : `${import.meta.env.BASE_URL}blog/${mainCategory}/`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const isoDate = (d: Date) => d.toISOString().replace('Z', '+08:00');
const dateObj = new Date(date);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
  "headline": title,
  "description": description,
  "inLanguage": "zh-TW",
  "datePublished": isoDate(dateObj),
  "dateModified": isoDate(dateObj),
  ...(image ? { "image": new URL(image, Astro.site).href } : {}),
  "author": {
    "@type": "Person",
    "name": "張惠芳 CFP"
  },
  "publisher": publisher
};
---
<BaseLayout title={`${title} | 諾昇理財規劃`} description={description} image={image} type="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="post-main">
    <div class="post-container">
      <nav class="breadcrumb">
        <a href={import.meta.env.BASE_URL}>首頁</a> &rsaquo;
        <a href={categoryUrl}>{categoryLabel}</a> &rsaquo;
        <span>{title}</span>
      </nav>

      <article class="post-article">
        <header class="post-header">
          <h1>{title}</h1>
          <div class="post-meta">
            <a href={categoryUrl} class="post-category-badge">{categoryLabel}</a>
            <span class="post-meta-sep">·</span>
            <span>張惠芳 CFP®</span>
            <span class="post-meta-sep">·</span>
            <span>{formattedDate}</span>
            <span class="post-meta-sep">·</span>
            <span>閱讀 {readingTime} 分鐘</span>
          </div>
          {image && (
            <div class="post-cover">
              <img src={getAssetPath(image, import.meta.env.BASE_URL)} alt={title} width="800" height="450" loading="lazy" sizes="(max-width: 860px) 100vw, 800px" />
            </div>
          )}
        </header>

        <div class="post-content">
          <Content />
        </div>
        <AuthorCard />
      </article>
    </div>
  </main>


</BaseLayout>

