---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
import { categoryLabels } from '../data/categories';
import { publisher } from '../utils/jsonld';
import { getAssetPath } from '../utils/assets';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.numericSlug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, image, categories } = post.data;

const formattedDate = new Date(date).toLocaleDateString('zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric'
});

// 閱讀時間估算（中文約 500 字/分鐘）
const body = post.body || '';
const charCount = body.replace(/\s/g, '').length;
const readingTime = Math.max(1, Math.ceil(charCount / 500));

const mainCategory = categories?.find(c => c !== 'blog') ?? 'blog';
const categoryLabel = categoryLabels[mainCategory] ?? '理財新知';
const categoryUrl = mainCategory === 'blog' ? `${import.meta.env.BASE_URL}blog/` : `${import.meta.env.BASE_URL}blog/${mainCategory}/`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const isoDate = (d: Date) => d.toISOString().replace('Z', '+08:00');
const dateObj = new Date(date);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
  "headline": title,
  "description": description,
  "inLanguage": "zh-TW",
  "datePublished": isoDate(dateObj),
  "dateModified": isoDate(dateObj),
  ...(image ? { "image": new URL(image, Astro.site).href } : {}),
  "author": {
    "@type": "Person",
    "name": "張惠芳 CFP"
  },
  "publisher": publisher
};

/* ── 前/後一篇導覽 ── */
/* 排序：新→舊（降序），與列表頁 sortPostsByDate 一致 */
/* 列表中 idx 小 = 較新，idx 大 = 較舊 */
/* 上一篇 = idx-1 = 較新的文章（列表中往上）*/
/* 下一篇 = idx+1 = 較舊的文章（列表中往下）*/
const base = import.meta.env.BASE_URL;
const allSorted = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

type NavItem = { title: string; url: string } | null;
type NavPair = { prev: NavItem; next: NavItem };

function buildNavPair(posts: typeof allSorted): NavPair {
  const idx = posts.findIndex(p => p.data.numericSlug === post.data.numericSlug);
  const prev = idx > 0 ? posts[idx - 1] : null;
  const next = idx < posts.length - 1 ? posts[idx + 1] : null;
  return {
    prev: prev ? { title: prev.data.title, url: `${base}${prev.data.numericSlug}/` } : null,
    next: next ? { title: next.data.title, url: `${base}${next.data.numericSlug}/` } : null,
  };
}

const navMap: Record<string, NavPair> = { all: buildNavPair(allSorted) };
const artCats = (categories || []).filter((c: string) => c !== 'blog');
for (const cat of artCats) {
  navMap[cat] = buildNavPair(allSorted.filter(p => p.data.categories?.includes(cat)));
}

const defaultNavCat = artCats.length > 0 ? mainCategory : 'all';
const defaultNav = navMap[defaultNavCat] || navMap.all;
const defaultNavLabel = defaultNavCat === 'all' ? '全部文章' : (categoryLabels[defaultNavCat] || '全部文章');
---
<BaseLayout title={`${title} | 諾昇理財規劃`} description={description} image={image} type="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="post-main">
    <div class="post-container">
      <nav class="breadcrumb">
        <a href={import.meta.env.BASE_URL}>首頁</a> &rsaquo;
        <a href={categoryUrl}>{categoryLabel}</a> &rsaquo;
        <span>{title}</span>
      </nav>

      <article class="post-article">
        <header class="post-header">
          <h1>{title}</h1>
          <div class="post-meta">
            <a href={categoryUrl} class="post-category-badge">{categoryLabel}</a>
            <span class="post-meta-sep">·</span>
            <span>張惠芳 CFP®</span>
            <span class="post-meta-sep">·</span>
            <span>{formattedDate}</span>
            <span class="post-meta-sep">·</span>
            <span>閱讀 {readingTime} 分鐘</span>
          </div>
          {image && (
            <div class="post-cover">
              <img src={getAssetPath(image, import.meta.env.BASE_URL)} alt={title} width="800" height="450" loading="lazy" sizes="(max-width: 860px) 100vw, 800px" />
            </div>
          )}
        </header>

        <div class="post-content">
          <Content />
        </div>
        <AuthorCard />

        {/* ── 前/後一篇導覽 ── */}
        <nav class="post-nav" id="postNav"
          data-nav={JSON.stringify(navMap)}
          data-default={defaultNavCat}
          data-cat-labels={JSON.stringify({ all: '全部文章', ...categoryLabels })}
        >
          <div class="post-nav-inner">
            {defaultNav.prev ? (
              <a href={defaultNav.prev.url} class="post-nav-link post-nav-prev" data-dir="prev">
                <span class="post-nav-label">← 上一篇</span>
                <span class="post-nav-title">{defaultNav.prev.title}</span>
              </a>
            ) : <span class="post-nav-link post-nav-placeholder" data-dir="prev"></span>}
            {defaultNav.next ? (
              <a href={defaultNav.next.url} class="post-nav-link post-nav-next" data-dir="next">
                <span class="post-nav-label">下一篇 →</span>
                <span class="post-nav-title">{defaultNav.next.title}</span>
              </a>
            ) : <span class="post-nav-link post-nav-placeholder" data-dir="next"></span>}
          </div>
          <div class="post-nav-context" id="postNavContext">
            瀏覽：{defaultNavLabel}
          </div>
        </nav>
      </article>
    </div>
  </main>

  {/* 依 ?cat= query param 動態切換導覽 context */}
  <script is:inline define:vars={{ defaultNavCat }}>
    (function() {
      var nav = document.getElementById('postNav');
      if (!nav) return;
      var navMap = JSON.parse(nav.dataset.nav || '{}');
      var catLabels = JSON.parse(nav.dataset.catLabels || '{}');
      var params = new URLSearchParams(window.location.search);
      var cat = params.get('cat') || defaultNavCat;
      var data = navMap[cat] || navMap[defaultNavCat] || navMap.all;
      if (!data) return;

      function setLink(dir, item) {
        var el = nav.querySelector('[data-dir="' + dir + '"]');
        if (!el) return;
        if (item) {
          var href = item.url + '?cat=' + encodeURIComponent(cat);
          if (el.tagName === 'SPAN') {
            var a = document.createElement('a');
            a.className = 'post-nav-link post-nav-' + dir;
            a.setAttribute('data-dir', dir);
            a.href = href;
            a.innerHTML = '<span class="post-nav-label">' +
              (dir === 'prev' ? '← 上一篇' : '下一篇 →') +
              '</span><span class="post-nav-title">' +
              item.title.replace(/</g,'&lt;') + '</span>';
            el.replaceWith(a);
          } else {
            el.href = href;
            el.querySelector('.post-nav-title').textContent = item.title;
          }
        } else {
          if (el.tagName === 'A') {
            var sp = document.createElement('span');
            sp.className = 'post-nav-link post-nav-placeholder';
            sp.setAttribute('data-dir', dir);
            el.replaceWith(sp);
          }
        }
      }

      setLink('prev', data.prev);
      setLink('next', data.next);

      // 也幫已存在的連結補上 ?cat=
      nav.querySelectorAll('a.post-nav-link').forEach(function(a) {
        if (a.href && a.href.indexOf('?cat=') === -1) {
          a.href = a.href.split('?')[0] + '?cat=' + encodeURIComponent(cat);
        }
      });

      var ctx = document.getElementById('postNavContext');
      if (ctx) ctx.textContent = '瀏覽：' + (catLabels[cat] || '全部文章');
    })();
  </script>
</BaseLayout>

