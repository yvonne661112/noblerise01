---
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Head from '../../../components/Head.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

const rawPosts = await getCollection('blog');
const posts = rawPosts
  .filter((p: Post) => p.data.categories?.includes('business-planning'))
  .sort((a: Post, b: Post) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

interface PostView {
  slug: string;
  title: string;
  image?: string;
  description: string;
  dateStr: string;
}

const postViews: PostView[] = posts.map((post: Post) => ({
  slug: post.data.numericSlug,
  title: post.data.title,
  image: post.data.image,
  description: post.data.description,
  dateStr: new Date(post.data.date).toLocaleDateString('zh-TW'),
}));
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="財務規劃 | 諾昇理財規劃" description="諾昇理財規劃 財務規劃 相關文章，由 CFP® 張惠芳撰寫，提供專業財務知識。" />
  
</head>
<body>
  <Header />

  <section class="hero-banner hero-inner">
    <div class="hero-content">
      <h1>財務規劃</h1>
    </div>
  </section>

  <main class="section">
    <div class="container">
      <div class="blog-grid">
        {postViews.map(p => (
          <article class="blog-card">
            {p.image && (
              <a href={`${import.meta.env.BASE_URL}${p.slug}/`}>
                <img src={p.image ? (import.meta.env.BASE_URL + p.image.replace(/^\//, '')) : ''} alt={p.title} width="400" height="250" loading="lazy" class="blog-card-img" />
              </a>
            )}
            <div class="blog-card-body">
              <h2><a href={`${import.meta.env.BASE_URL}${p.slug}/`}>{p.title}</a></h2>
              <div class="blog-card-meta">
                <span>諾昇理財規劃顧問｜張惠芳 CFP</span>
                <span>|</span>
                <span>{p.dateStr}</span>
                <span>|</span>
                <a href={import.meta.env.BASE_URL + "blog/business-planning/"}>財務規劃</a>
              </div>
              <p class="blog-card-excerpt">{p.description.slice(0, 60)}…</p>
              <a href={`${import.meta.env.BASE_URL}${p.slug}/`} class="read-more">read more »</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>
