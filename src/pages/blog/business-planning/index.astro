---
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Head from '../../../components/Head.astro';
import BlogList from '../../../components/BlogList.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

const rawPosts = await getCollection('blog');
const posts = rawPosts
  .filter((p: Post) => p.data.categories?.includes('business-planning'))
  .sort((a: Post, b: Post) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postViews = posts.map((post: Post) => ({
  slug: post.data.numericSlug,
  title: post.data.title,
  image: post.data.image,
  description: post.data.description,
  dateStr: new Date(post.data.date).toLocaleDateString('zh-TW'),
  catLabel: '財務規劃',
  catUrl: import.meta.env.BASE_URL + 'blog/business-planning/',
}));
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="財務規劃 | 諾昇理財規劃" description="諾昇理財規劃 財務規劃 相關文章，由 CFP® 張惠芳撰寫，提供專業財務知識。" />
</head>
<body>
  <Header />

  <div class="page-title-bar">
    <div class="container">
      <h1>財務規劃</h1>
    </div>
  </div>

  <main class="section">
    <div class="container">
      <BlogList posts={postViews} currentCat="business-planning" />
    </div>
  </main>

  <Footer />
</body>
</html>
