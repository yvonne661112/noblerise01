---
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Head from '../../../components/Head.astro';
import BlogList from '../../../components/BlogList.astro';
import PageHero from '../../../components/PageHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

const categoryLabels: Record<string, string> = {
  investment:          '投資理財',
  insurance:           '保險權益',
  certification:       '證照進修',
  'business-planning': '財務規劃',
  'elderly-care-trust':'信託規劃',
  'tax-planning':      '傳承稅務',
};

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return Object.keys({
    investment: 1,
    insurance: 1,
    certification: 1,
    'business-planning': 1,
    'elderly-care-trust': 1,
    'tax-planning': 1,
  }).map(slug => ({ params: { category: slug }, props: { allPosts } }));
}

const { category } = Astro.params;
const { allPosts } = Astro.props;

const label = categoryLabels[category] ?? '理財新知';

const posts = (allPosts as Post[])
  .filter(p => p.data.categories?.includes(category))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postViews = posts.map(post => {
  const catLabels = (post.data.categories ?? [])
    .filter(c => c !== 'blog' && categoryLabels[c])
    .map(c => categoryLabels[c]);
  return {
    slug: post.data.numericSlug,
    title: post.data.title,
    image: post.data.image,
    description: post.data.description,
    dateStr: new Date(post.data.date).toLocaleDateString('zh-TW'),
    catLabel: label,
    catUrl: import.meta.env.BASE_URL + `blog/${category}/`,
    tags: post.data.tags ?? [],
    catLabels,
  };
});
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head
    title={`${label} | 諾昇理財規劃`}
    description={`諾昇理財規劃 ${label} 相關文章，由 CFP® 張惠芳撰寫，提供專業財務知識。`}
  />
</head>
<body>
  <Header />

  <PageHero eyebrow="Knowledge" title={label} />

  <main class="section">
    <div class="container">
      <BlogList posts={postViews} currentCat={category} />
    </div>
  </main>

  <Footer />
</body>
</html>
