---
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Head from '../../../components/Head.astro';
import BlogList from '../../../components/BlogList.astro';
import PageHero from '../../../components/PageHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { categoryLabels, categorySlugs } from '../../../data/categories';
import { sortPostsByDate, transformPost } from '../../../utils/post';
import { blogListLd, breadcrumbLd } from '../../../utils/jsonld';

type Post = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return categorySlugs.map(slug => ({ params: { category: slug }, props: { allPosts } }));
}

const { category } = Astro.params;
const { allPosts } = Astro.props;
const base = import.meta.env.BASE_URL;

const label = categoryLabels[category] ?? '理財新知';

const posts = sortPostsByDate(
  (allPosts as Post[]).filter(p => p.data.categories?.includes(category))
);
const postViews = posts.map(p => transformPost(p, base));

const crumbLd = breadcrumbLd([
  { name: '首頁', item: 'https://noblerise.com.tw/' },
  { name: '理財新知', item: 'https://noblerise.com.tw/blog/' },
  { name: label, item: `https://noblerise.com.tw/blog/${category}/` },
]);

const jsonLd = blogListLd({
  type: 'CollectionPage',
  name: `${label} | 諾昇理財規劃`,
  description: `諾昇理財規劃 ${label} 相關文章，由 CFP® 張惠芳撰寫，提供專業財務知識。`,
  url: `https://noblerise.com.tw/blog/${category}/`,
  hasPart: posts.map(p => ({
    url: `https://noblerise.com.tw/${p.data.numericSlug}/`,
    headline: p.data.title,
    datePublished: String(p.data.date),
  })),
});
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head
    title={`${label} | 諾昇理財規劃`}
    description={`諾昇理財規劃 ${label} 相關文章，由 CFP® 張惠芳撰寫，提供專業財務知識。`}
  />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbLd)} />
</head>
<body>
  <Header />

  <PageHero eyebrow="Knowledge" title={label} />

  <main class="section">
    <div class="container">
      <BlogList posts={postViews} currentCat={category} />
    </div>
  </main>

  <Footer />
</body>
</html>
