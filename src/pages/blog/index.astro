---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Post = CollectionEntry<'blog'>;

const categoryLabels: Record<string, string> = {
  investment: '投資理財',
  insurance: '保險權益',
  certification: '證照進修',
  'business-planning': '財務規劃',
  'elderly-care-trust': '信託規劃',
  'tax-planning': '傳承稅務',
};

const rawPosts = await getCollection('blog');
const posts = rawPosts.sort(
  (a: Post, b: Post) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

interface PostView {
  slug: string;
  title: string;
  image?: string;
  description: string;
  dateStr: string;
  catLabel: string;
  catUrl: string;
}

const postViews: PostView[] = posts.map((post: Post) => {
  const mainCat = post.data.categories?.find((c: string) => c !== 'blog') ?? '';
  return {
    slug: post.data.numericSlug,
    title: post.data.title,
    image: post.data.image,
    description: post.data.description,
    dateStr: new Date(post.data.date).toLocaleDateString('zh-TW'),
    catLabel: categoryLabels[mainCat] ?? '理財新知',
    catUrl: mainCat ? (import.meta.env.BASE_URL + `blog/${mainCat}/`) : (import.meta.env.BASE_URL + 'blog/'),
  };
});
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="理財新知 | 諾昇理財規劃" description="諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。" />
  
</head>
<body>
  <Header />

  <div class="page-title-bar">
    <div class="container">
      <h1>理財新知</h1>
    </div>
  </div>

  <main class="section">
    <div class="container">
      <div class="blog-list">
        {postViews.map(p => (
          <article class="blog-list-card">
            <a href={`${import.meta.env.BASE_URL}${p.slug}/`} class="blog-list-img-wrap">
              {p.image
                ? <img src={import.meta.env.BASE_URL + p.image.replace(/^\//, '')} alt={p.title} width="320" height="200" loading="lazy" />
                : <div class="blog-list-img-placeholder"></div>
              }
            </a>
            <div class="blog-list-body">
              <div class="blog-card-meta">
                <span>張惠芳 CFP®</span>
                <span>·</span>
                <span>{p.dateStr}</span>
                <span>·</span>
                <a href={p.catUrl}>{p.catLabel}</a>
              </div>
              <h2><a href={`${import.meta.env.BASE_URL}${p.slug}/`}>{p.title}</a></h2>
              <p class="blog-card-excerpt">{p.description.slice(0, 100)}…</p>
              <a href={`${import.meta.env.BASE_URL}${p.slug}/`} class="read-more">閱讀全文</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</body>
</html>
