---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import BlogList from '../../components/BlogList.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { sortPostsByDate, transformPost } from '../../utils/post';

const base = import.meta.env.BASE_URL;
const posts = sortPostsByDate(await getCollection('blog'));
const postViews = posts.map(p => transformPost(p, base));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "理財新知 | 諾昇理財規劃",
  "description": "諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。",
  "url": "https://noblerise.com.tw/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "諾昇理財規劃顧問股份有限公司",
    "url": "https://noblerise.com.tw"
  }
};

---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="理財新知 | 諾昇理財規劃" description="諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header />

  <PageHero eyebrow="Knowledge" title="知識文章" />

  <main class="section">
    <div class="container">
      <BlogList posts={postViews} currentCat="" />
    </div>
  </main>

  <Footer />
</body>
</html>
