---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import BlogList from '../../components/BlogList.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { categoryLabels } from '../../data/categories';

type Post = CollectionEntry<'blog'>;

const rawPosts = await getCollection('blog');
const posts = rawPosts.sort(
  (a: Post, b: Post) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "理財新知 | 諾昇理財規劃",
  "description": "諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。",
  "url": "https://noblerise.com.tw/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "諾昇理財規劃顧問股份有限公司",
    "url": "https://noblerise.com.tw"
  }
};

const postViews = posts.map((post: Post) => {
  const mainCat = post.data.categories?.find((c: string) => c !== 'blog') ?? '';
  const catLabels = (post.data.categories ?? [])
    .filter((c: string) => c !== 'blog' && categoryLabels[c])
    .map((c: string) => categoryLabels[c]);
  return {
    slug: post.data.numericSlug,
    title: post.data.title,
    image: post.data.image,
    description: post.data.description,
    dateStr: new Date(post.data.date).toLocaleDateString('zh-TW'),
    catLabel: categoryLabels[mainCat] ?? '理財新知',
    catUrl: mainCat ? (import.meta.env.BASE_URL + `blog/${mainCat}/`) : (import.meta.env.BASE_URL + 'blog/'),
    tags: post.data.tags ?? [],
    catLabels,
  };
});
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="理財新知 | 諾昇理財規劃" description="諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <Header />

  <PageHero eyebrow="Knowledge" title="知識文章" />

  <main class="section">
    <div class="container">
      <BlogList posts={postViews} currentCat="" />
    </div>
  </main>

  <Footer />
</body>
</html>
