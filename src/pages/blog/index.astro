---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Head from '../../components/Head.astro';
import BlogList from '../../components/BlogList.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';
import { sortPostsByDate, transformPost } from '../../utils/post';
import { blogListLd, breadcrumbLd } from '../../utils/jsonld';

const base = import.meta.env.BASE_URL;
const posts = sortPostsByDate(await getCollection('blog'));
const postViews = posts.map(p => transformPost(p, base));

const jsonLd = blogListLd({
  type: 'Blog',
  name: '理財新知 | 諾昇理財規劃',
  description: '諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。',
  url: 'https://noblerise.com.tw/blog/',
});

const crumbLd = breadcrumbLd([
  { name: '首頁', item: 'https://noblerise.com.tw/' },
  { name: '理財新知', item: 'https://noblerise.com.tw/blog/' },
]);

---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <Head title="理財新知 | 諾昇理財規劃" description="諾昇理財規劃知識文章，涵蓋投資理財、保險權益、財務規劃、信託規劃、傳承稅務、證照進修等主題，由 CFP® 張惠芳撰寫。" />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(crumbLd)} />
</head>
<body>
  <Header />

  <PageHero
    eyebrow="Knowledge"
    title="理財新知"
    description="專業觀點、實用知識，幫助你做出更好的財務決策。"
  />

  <main class="section">
    <div class="container">
      <div class="blog-count">共 {postViews.length} 篇文章</div>
      <BlogList posts={postViews} currentCat="" />
    </div>
  </main>

  <Footer />
</body>
</html>

<style>
  .blog-count {
    font-size: var(--fs-sm);
    color: var(--color-text-mid);
    margin-bottom: 8px;
    text-align: right;
  }
</style>
