---
/**
 * FloatingButtons — 右下角浮動聯絡按鈕（LINE / YouTube / Email）
 * 顯示開關：siteConfig.SHOW_FLOATING_BUTTONS
 * 樣式變數：--floating-btn-size、--floating-btn-size-sm、--color-youtube（定義於 theme CSS）
 */
import { CONTACT, SHOW_FLOATING_BUTTONS } from '../data/siteConfig';
const base = import.meta.env.BASE_URL;
---

{SHOW_FLOATING_BUTTONS && (
  <div class="floating-contacts">
    <a href={CONTACT.lineUrl} target="_blank" rel="noopener noreferrer" class="floating-btn" aria-label="LINE 聯繫我們">
      <img src={`${base}images/LINE_New_App_Icon.png`} alt="LINE" width="52" height="52" />
    </a>
    <a href="https://www.youtube.com/channel/UC23W3r9y9tVDcXMOXuwpPHg/about" target="_blank" rel="noopener noreferrer" class="floating-btn floating-btn--youtube" aria-label="YouTube 頻道">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
        <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 0 0 .5 6.19 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.81 3.02 3.02 0 0 0 2.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
      </svg>
    </a>
    <a href={`mailto:${CONTACT.email}`} class="floating-btn floating-btn--email" aria-label="Email 聯繫我們">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
        <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
      </svg>
    </a>
  </div>
)}

<style>
  .floating-contacts {
    position: fixed;
    right: 32px;
    bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 50;
  }
  .floating-btn {
    width: var(--floating-btn-size);
    height: var(--floating-btn-size);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-on-primary);
    text-decoration: none;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  .floating-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }
  .floating-btn--youtube {
    background: var(--color-youtube);
  }
  .floating-btn--email {
    background: var(--color-accent);
  }
  @media (max-width: 600px) {
    .floating-contacts { right: 14px; bottom: 20px; }
    .floating-btn {
      width: var(--floating-btn-size-sm);
      height: var(--floating-btn-size-sm);
    }
  }
</style>
