---
/**
 * 櫻花飄落特效元件
 * 開關：src/data/siteConfig.ts → SHOW_SAKURA
 */
---
<div class="sakura-container" aria-hidden="true"></div>

<style is:global>
  .sakura-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 9999;
  }

  /* 外層：負責垂直下落 + 淡入淡出 */
  .sakura-wrap {
    position: absolute;
    top: -20px;
    animation: sakura-drop linear forwards;
    opacity: 0;
  }

  /* 內層：負責水平飄移（獨立 ease-in-out，不影響下落速度） */
  .sakura-petal {
    border-radius: 50% 0 50% 0;
    background: radial-gradient(ellipse at 40% 35%, #fff 0%, #ffb7c5 55%, #e8799a 100%);
    animation: sakura-sway ease-in-out infinite alternate;
  }

  @keyframes sakura-drop {
    0%   { transform: translateY(0)     rotate(0deg)   scale(1);   opacity: 0; }
    6%   {                                                          opacity: 0.85; }
    88%  {                                                          opacity: 0.65; }
    100% { transform: translateY(108vh) rotate(var(--spin)) scale(0.8); opacity: 0; }
  }

  @keyframes sakura-sway {
    from { transform: translateX(calc(var(--sway) * -1)) rotate(0deg); }
    to   { transform: translateX(var(--sway))            rotate(25deg); }
  }
</style>

<script>
  (function () {
    const container = document.querySelector('.sakura-container');
    if (!container) return;

    function spawnPetal() {
      const size = Math.random() * 10 + 8;

      const wrap = document.createElement('div');
      wrap.className = 'sakura-wrap';
      wrap.style.left   = Math.random() * 105 + 'vw';

      const inner = document.createElement('div');
      inner.className = 'sakura-petal';
      inner.style.width  = size + 'px';
      inner.style.height = size * (Math.random() * 0.4 + 0.7) + 'px';

      // 下落總時長
      const dur = Math.random() * 4 + 6;
      wrap.style.animationDuration = dur + 's';

      // 旋轉角度（各自不同）
      const spin = (Math.random() > 0.5 ? 1 : -1) * (Math.random() * 360 + 180);
      wrap.style.setProperty('--spin', spin + 'deg');

      // 水平飄移幅度與速度（獨立於下落）
      const sway = Math.random() * 18 + 6;          // 6–24 px
      const swayDur = Math.random() * 1.2 + 0.8;    // 0.8–2 s 一來回
      inner.style.setProperty('--sway', sway + 'px');
      inner.style.animationDuration = swayDur + 's';

      wrap.appendChild(inner);
      container.appendChild(wrap);
      setTimeout(() => wrap.remove(), dur * 1000 + 200);
    }

    for (let i = 0; i < 12; i++) {
      setTimeout(spawnPetal, Math.random() * 3000);
    }
    setInterval(spawnPetal, 600);
  })();
</script>
