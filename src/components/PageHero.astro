---
interface Stat {
  num: string;
  label: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  stats?: Stat[];
}
const { eyebrow, title, description, stats } = Astro.props;
---
<section class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-inner">
    {eyebrow && <div class="page-hero-eyebrow">{eyebrow}</div>}
    <h1 class="page-hero-title" set:html={title} />
    {description && <p class="page-hero-desc">{description}</p>}
    {stats && stats.length > 0 && (
      <div class="page-hero-stats">
        {stats.map(s => (
          <div>
            <span class="page-hero-stat-num">{s.num}</span>
            <span class="page-hero-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background: var(--color-primary);
    padding: 64px 4rem 56px;
    color: #fff;
  }
  /* 格紋裝飾層（Premium 透過 --hero-pattern 啟用；Classic 為 none） */
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-image: var(--hero-pattern);
    background-size: auto, auto, 40px 40px, 40px 40px;
    pointer-events: none;
  }
  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  /* eyebrow */
  .page-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }
  .page-hero-eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: var(--color-accent);
  }

  /* title */
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 5vw, 48px);
    font-weight: var(--heading-weight);
    color: #fff;
    line-height: 1.3;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  /* description */
  .page-hero-desc {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.9;
    max-width: 520px;
  }

  /* stats row */
  .page-hero-stats {
    display: flex;
    gap: 3rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .page-hero-stat-num {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: var(--heading-weight);
    color: var(--color-accent-light);
    display: block;
    line-height: 1;
    margin-bottom: 4px;
  }
  .page-hero-stat-label {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.06em;
  }

  @media (max-width: 900px) {
    .page-hero { padding: 48px 1.5rem 44px; }
    .page-hero-stats { gap: 2rem; }
  }
</style>
