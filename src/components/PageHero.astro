---
interface Stat {
  num: string;
  label: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  description?: string;
  backgroundImage?: string;
  stats?: Stat[];
  center?: boolean;
  large?: boolean;
}
const { eyebrow, title, subtitle, description, backgroundImage, stats, center = true, large = false } = Astro.props;
const hasSlot = Astro.slots.has('default');
const base = import.meta.env.BASE_URL;
const bgUrl = backgroundImage ? `${base}${backgroundImage}` : null;
---
<section class:list={['page-hero', { 'page-hero--has-bg': !!bgUrl, 'page-hero--center': center, 'page-hero--large': large }]}>
  {bgUrl && <div class="page-hero-img" style={`background-image: url('${bgUrl}')`}></div>}
  <div class="page-hero-overlay"></div>
  <div class="page-hero-accent"></div>
  <div class="page-hero-inner">
    {eyebrow && <div class="page-hero-eyebrow">{eyebrow}</div>}
    <h1 class="page-hero-title" set:html={title} />
    {subtitle && <p class="page-hero-subtitle">{subtitle}</p>}
    {description && <p class="page-hero-desc" set:html={description} />}
    {stats && stats.length > 0 && (
      <div class="page-hero-stats">
        {stats.map(s => (
          <div>
            <span class="page-hero-stat-num">{s.num}</span>
            <span class="page-hero-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    )}
    {hasSlot && <div class="page-hero-actions"><slot /></div>}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    background: var(--hero-gradient, var(--color-primary));
    padding: var(--hero-padding);
    color: var(--color-on-primary);
  }
  .page-hero--has-bg { min-height: 340px; display: flex; align-items: center; justify-content: center; }
  .page-hero--large { min-height: 520px; padding-top: 72px; padding-bottom: 64px; }
  .page-hero--large .page-hero-title { font-size: var(--hero-title-size); }
  .page-hero--center .page-hero-inner { text-align: center; }
  .page-hero--center .page-hero-desc { margin-left: auto; margin-right: auto; }

  /* 背景圖（有圖時） */
  .page-hero-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* overlay：有圖時漸層遮色 / 無圖時 pattern 裝飾 */
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .page-hero--has-bg .page-hero-overlay {
    background: linear-gradient(135deg, rgba(10, 46, 48, 0.9) 0%, rgba(13, 56, 58, 0.82) 40%, rgba(21, 69, 72, 0.78) 100%);
  }
  .page-hero:not(.page-hero--has-bg) .page-hero-overlay {
    background-image: var(--hero-pattern);
    background-size: 24px 24px;
  }

  .page-hero-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--color-accent) 30%, var(--color-accent) 70%, transparent);
    z-index: 2;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
  }

  /* eyebrow */
  .page-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: var(--hero-eyebrow-size, var(--fs-xs));
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: 16px;
  }
  .page-hero-eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: var(--color-accent);
  }
  .page-hero--center .page-hero-eyebrow { justify-content: center; }
  .page-hero--center .page-hero-eyebrow::before { display: none; }

  /* title */
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: var(--hero-title-size);
    font-weight: var(--heading-weight);
    color: var(--color-on-primary);
    line-height: 1.35;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }

  /* subtitle */
  .page-hero-subtitle {
    font-size: var(--fs-lg);
    color: var(--hero-subtitle-color);
    line-height: 1.6;
    margin-bottom: 8px;
    font-weight: var(--hero-subtitle-weight);
  }

  /* description */
  .page-hero-desc {
    font-size: var(--hero-desc-size);
    color: var(--hero-desc-color);
    line-height: 1.8;
    max-width: var(--hero-desc-max-width);
  }

  /* stats row */
  .page-hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--hero-stats-border);
  }
  .page-hero--center .page-hero-stats { justify-content: center; }
  .page-hero-stat-num {
    font-family: var(--font-heading);
    font-size: var(--hero-stat-num-size);
    font-weight: var(--heading-weight);
    color: var(--color-accent-light);
    display: block;
    line-height: 1;
    margin-bottom: 4px;
  }
  .page-hero-stat-label {
    font-size: var(--fs-xs);
    color: var(--hero-stat-label-color);
    letter-spacing: 0.06em;
  }

  /* actions slot */
  .page-hero-actions {
    display: flex;
    gap: 16px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .page-hero--center .page-hero-actions { justify-content: center; }

  @media (max-width: 900px) {
    .page-hero { padding: var(--hero-padding-mobile); }
    .page-hero--has-bg { min-height: 280px; }
    .page-hero--large { min-height: 440px; }
    .page-hero-stats { gap: 2rem; }
  }
  @media (max-width: 600px) {
    .page-hero--large { min-height: 400px; }
    .page-hero-stats { flex-direction: column; gap: 1.25rem; }
  }
</style>
