---
import '../styles/global.css';
import { activeTheme } from '../data/siteConfig';
import { getAssetPath } from '../utils/assets';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
}
const { title, description, image = '/images/og-default.jpg', type = 'website' } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteImageUrl = new URL(getAssetPath(image, base), Astro.site);

const fontUrls: Record<typeof activeTheme, string> = {
  classic:       'https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Poppins:wght@400;500;600&family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap',
  premium:       'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500&display=swap',
  prestige:      'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Noto+Serif+TC:wght@400;500;700&family=Noto+Sans+TC:wght@300;400;500&display=swap',
  'premium-dark':'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500&display=swap',
  kawazu:        'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Cormorant+Garamond:wght@400;500;600&family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500&display=swap',
  kintsugi:      'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Cormorant+Infant:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500&display=swap',
  noble:         'https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap',
};
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<link rel="icon" type="image/png" href={`${base}favicon.png`} />
<link rel="apple-touch-icon" href={`${base}favicon.png`} />
<meta name="description" content={description} />
<meta name="robots" content="noindex, nofollow" />
<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />
<link rel="alternate" hreflang="zh-TW" href={canonicalURL} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={absoluteImageUrl} />
<meta property="og:locale" content="zh_TW" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImageUrl} />
<!-- Theme CSS（切換主題只需改 siteConfig.ts 的 activeTheme） -->
<link rel="stylesheet" href={`${base}styles/theme-${activeTheme}.css`} data-theme-link />
<!-- Google Fonts（依主題載入對應字型） -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
<link href={fontUrls[activeTheme]} rel="stylesheet" data-font-link />
<!-- Dev theme restore：讀取 localStorage 即時替換主題，避免閃爍 -->
<script is:inline define:vars={{ base, fontUrls }}>
(function(){
  var t = localStorage.getItem('dev-theme');
  if (!t) return;
  var tl = document.querySelector('[data-theme-link]');
  var fl = document.querySelector('[data-font-link]');
  if (tl) tl.setAttribute('href', base + 'styles/theme-' + t + '.css');
  if (fl && fontUrls[t]) fl.setAttribute('href', fontUrls[t]);
})();
</script>
