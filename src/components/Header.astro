---
import SakuraRain from './SakuraRain.astro';
import { SHOW_SAKURA, SHOW_DEV_PAGE, CONTACT } from '../data/siteConfig';
import { mainNav } from '../data/navLinks';
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

/** 判斷目前路徑是否符合此導覽連結 */
function isActive(href: string): boolean {
  const full = base + href;
  if (href === '') return path === base || path === base.replace(/\/$/, '');
  return path.startsWith(full);
}
---
<div data-dev-feature="sakura" style={SHOW_SAKURA ? undefined : 'display:none'}><SakuraRain /></div>
<header class="site-header">
  <div class="header-inner">
    <a href={base} class="logo-link">
      <img src={base + "images/header-logo.jpg"} alt="諾昇理財規劃" width="130" height="80" loading="eager" />
    </a>
    <div class="header-right">
      <nav class="main-nav">
        <ul>
          {mainNav.map(item => item.children ? (
            <li class="has-sub">
              <a href={base + item.href} class:list={[isActive(item.href) && 'active']}>{item.label}</a>
              <ul class="sub-menu">
                {item.children.map(child => (
                  <li><a href={base + child.href}>{child.label}</a></li>
                ))}
              </ul>
            </li>
          ) : (
            <li><a href={base + item.href} class:list={[isActive(item.href) && 'active']}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
      {SHOW_DEV_PAGE && <a href={base + "dev/"} class="dev-dot-link" aria-label="Dev">.</a>}
    </div>
    <!-- 漢堡按鈕（手機版） -->
    <button class="mobile-menu-btn" aria-label="開啟選單" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- 手機側邊選單 -->
<div class="mobile-overlay"></div>
<nav class="mobile-nav">
  <button class="mobile-nav-close" aria-label="關閉選單">✕</button>
  <ul>
    {mainNav.map(item => item.children ? (
      <li>
        <a href={base + item.href} class:list={[isActive(item.href) && 'active']}>{item.label}</a>
        <ul class="mobile-sub">
          {item.children.map(child => (
            <li><a href={base + child.href}>{child.label}</a></li>
          ))}
        </ul>
      </li>
    ) : (
      <li><a href={base + item.href} class:list={[isActive(item.href) && 'active']}>{item.label}</a></li>
    ))}
    {SHOW_DEV_PAGE && <li><a href={base + "dev/"} class:list={[isActive("dev/") && 'active']}>.</a></li>}
  </ul>
</nav>

<script>
  const btn = document.querySelector('.mobile-menu-btn') as HTMLButtonElement;
  const nav = document.querySelector('.mobile-nav') as HTMLElement;
  const overlay = document.querySelector('.mobile-overlay') as HTMLElement;
  const closeBtn = document.querySelector('.mobile-nav-close') as HTMLButtonElement;

  function openMenu() {
    nav.classList.add('open');
    overlay.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    nav.classList.remove('open');
    overlay.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }

  btn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', closeMenu);
</script>
