---
import SakuraRain from './SakuraRain.astro';
import { SHOW_SAKURA, SHOW_DEV_PAGE, CONTACT } from '../data/siteConfig';
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

/** 判斷目前路徑是否符合此導覽連結 */
function isActive(href: string): boolean {
  if (href === base) return path === base || path === base.replace(/\/$/, '');
  return path.startsWith(href);
}
---
<div data-dev-feature="sakura" style={SHOW_SAKURA ? undefined : 'display:none'}><SakuraRain /></div>
<header class="site-header">
  <div class="header-inner">
    <a href={base} class="logo-link">
      <img src={base + "images/header-logo.jpg"} alt="諾昇理財規劃" width="130" height="80" loading="eager" />
    </a>
    <div class="header-right">
      <nav class="main-nav">
        <ul>
          <li><a href={base} class:list={[isActive(base) && 'active']}>首頁</a></li>
          <li class="has-sub">
            <a href={base + "about/"} class:list={[isActive(base + "about/") && 'active']}>關於諾昇</a>
            <ul class="sub-menu">
              <li><a href={base + "about/策略夥伴/"}>策略夥伴</a></li>
            </ul>
          </li>
          <li><a href={base + "service/"} class:list={[isActive(base + "service/") && 'active']}>服務項目</a></li>
          <li class="has-sub">
            <a href={base + "blog/"} class:list={[isActive(base + "blog/") && 'active']}>知識文章</a>
            <ul class="sub-menu">
              <li><a href={base + "blog/investment/"}>投資理財</a></li>
              <li><a href={base + "blog/insurance/"}>保險權益</a></li>
              <li><a href={base + "blog/certification/"}>證照進修</a></li>
              <li><a href={base + "blog/business-planning/"}>財務規劃</a></li>
              <li><a href={base + "blog/elderly-care-trust/"}>信託規劃</a></li>
              <li><a href={base + "blog/tax-planning/"}>傳承稅務</a></li>
            </ul>
          </li>
          <li><a href={base + "contact/"} class:list={[isActive(base + "contact/") && 'active']}>聯絡我們</a></li>
          {SHOW_DEV_PAGE && <li><a href={base + "dev/"} class:list={[isActive(base + "dev/") && 'active']}>Dev</a></li>}
        </ul>
      </nav>
    </div>
    <!-- 漢堡按鈕（手機版） -->
    <button class="mobile-menu-btn" aria-label="開啟選單" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- 手機側邊選單 -->
<div class="mobile-overlay"></div>
<nav class="mobile-nav">
  <button class="mobile-nav-close" aria-label="關閉選單">✕</button>
  <ul>
    <li><a href={base} class:list={[isActive(base) && 'active']}>首頁</a></li>
    <li>
      <a href={base + "about/"} class:list={[isActive(base + "about/") && 'active']}>關於諾昇</a>
      <ul class="mobile-sub">
        <li><a href={base + "about/策略夥伴/"}>策略夥伴</a></li>
      </ul>
    </li>
    <li><a href={base + "service/"} class:list={[isActive(base + "service/") && 'active']}>服務項目</a></li>
    <li>
      <a href={base + "blog/"} class:list={[isActive(base + "blog/") && 'active']}>知識文章</a>
      <ul class="mobile-sub">
        <li><a href={base + "blog/investment/"}>投資理財</a></li>
        <li><a href={base + "blog/insurance/"}>保險權益</a></li>
        <li><a href={base + "blog/certification/"}>證照進修</a></li>
        <li><a href={base + "blog/business-planning/"}>財務規劃</a></li>
        <li><a href={base + "blog/elderly-care-trust/"}>信託規劃</a></li>
        <li><a href={base + "blog/tax-planning/"}>傳承稅務</a></li>
      </ul>
    </li>
    <li><a href={base + "contact/"} class:list={[isActive(base + "contact/") && 'active']}>聯絡我們</a></li>
    {SHOW_DEV_PAGE && <li><a href={base + "dev/"} class:list={[isActive(base + "dev/") && 'active']}>Dev</a></li>}
  </ul>
</nav>

<script>
  const btn = document.querySelector('.mobile-menu-btn') as HTMLButtonElement;
  const nav = document.querySelector('.mobile-nav') as HTMLElement;
  const overlay = document.querySelector('.mobile-overlay') as HTMLElement;
  const closeBtn = document.querySelector('.mobile-nav-close') as HTMLButtonElement;

  function openMenu() {
    nav.classList.add('open');
    overlay.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    nav.classList.remove('open');
    overlay.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }

  btn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', closeMenu);
</script>
