---
<header class="site-header">
  <div class="header-inner">
    <a href={import.meta.env.BASE_URL} class="logo-link">
      <img src={import.meta.env.BASE_URL + "images/footer-logo.jpg"} alt="諾昇理財規劃" width="130" height="80" loading="eager" />
    </a>
    <div class="header-right">
      <div class="header-company">
        <span class="header-company-cn">諾昇理財規劃顧問股份有限公司</span>
        <span class="header-company-en">NobleRise Financial Planning Consultant co., LTD.</span>
      </div>
      <nav class="main-nav">
        <ul>
          <li><a href={import.meta.env.BASE_URL}>首頁</a></li>
          <li class="has-sub">
            <a href={import.meta.env.BASE_URL + "about/"}>關於諾昇</a>
            <ul class="sub-menu">
              <li><a href={import.meta.env.BASE_URL + "about/策略夥伴/"}>策略夥伴</a></li>
            </ul>
          </li>
          <li><a href={import.meta.env.BASE_URL + "service/"}>服務項目</a></li>
          <li class="has-sub">
            <a href={import.meta.env.BASE_URL + "blog/"}>知識文章</a>
            <ul class="sub-menu">
              <li><a href={import.meta.env.BASE_URL + "blog/investment/"}>投資理財</a></li>
              <li><a href={import.meta.env.BASE_URL + "blog/insurance/"}>保險權益</a></li>
              <li><a href={import.meta.env.BASE_URL + "blog/certification/"}>證照進修</a></li>
              <li><a href={import.meta.env.BASE_URL + "blog/business-planning/"}>財務規劃</a></li>
              <li><a href={import.meta.env.BASE_URL + "blog/elderly-care-trust/"}>信託規劃</a></li>
              <li><a href={import.meta.env.BASE_URL + "blog/tax-planning/"}>傳承稅務</a></li>
            </ul>
          </li>
          <li><a href={import.meta.env.BASE_URL + "contact/"}>聯絡我們</a></li>
        </ul>
      </nav>
    </div>
    <!-- 漢堡按鈕（手機版） -->
    <button class="mobile-menu-btn" aria-label="開啟選單" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- 手機側邊選單 -->
<div class="mobile-overlay"></div>
<nav class="mobile-nav">
  <button class="mobile-nav-close" aria-label="關閉選單">✕</button>
  <ul>
    <li><a href={import.meta.env.BASE_URL}>首頁</a></li>
    <li>
      <a href={import.meta.env.BASE_URL + "about/"}>關於諾昇</a>
      <ul class="mobile-sub">
        <li><a href={import.meta.env.BASE_URL + "about/策略夥伴/"}>策略夥伴</a></li>
      </ul>
    </li>
    <li><a href={import.meta.env.BASE_URL + "service/"}>服務項目</a></li>
    <li>
      <a href={import.meta.env.BASE_URL + "blog/"}>知識文章</a>
      <ul class="mobile-sub">
        <li><a href={import.meta.env.BASE_URL + "blog/investment/"}>投資理財</a></li>
        <li><a href={import.meta.env.BASE_URL + "blog/insurance/"}>保險權益</a></li>
        <li><a href={import.meta.env.BASE_URL + "blog/certification/"}>證照進修</a></li>
        <li><a href={import.meta.env.BASE_URL + "blog/business-planning/"}>財務規劃</a></li>
        <li><a href={import.meta.env.BASE_URL + "blog/elderly-care-trust/"}>信託規劃</a></li>
        <li><a href={import.meta.env.BASE_URL + "blog/tax-planning/"}>傳承稅務</a></li>
      </ul>
    </li>
    <li><a href={import.meta.env.BASE_URL + "contact/"}>聯絡我們</a></li>
  </ul>
</nav>

<script>
  const btn = document.querySelector('.mobile-menu-btn') as HTMLButtonElement;
  const nav = document.querySelector('.mobile-nav') as HTMLElement;
  const overlay = document.querySelector('.mobile-overlay') as HTMLElement;
  const closeBtn = document.querySelector('.mobile-nav-close') as HTMLButtonElement;

  function openMenu() {
    nav.classList.add('open');
    overlay.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }
  function closeMenu() {
    nav.classList.remove('open');
    overlay.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  }

  btn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', closeMenu);
</script>
