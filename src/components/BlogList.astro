---
interface PostView {
  slug: string;
  title: string;
  image?: string;
  description: string;
  dateStr: string;
  catLabel: string;
  catUrl: string;
  tags?: string[];
  catLabels?: string[];
}

interface Props {
  posts: PostView[];
  currentCat?: string;
}

const { posts, currentCat = '' } = Astro.props;

const categories = [
  { slug: '',                 label: '全部文章',  url: import.meta.env.BASE_URL + 'blog/' },
  { slug: 'investment',       label: '投資理財',  url: import.meta.env.BASE_URL + 'blog/investment/' },
  { slug: 'insurance',        label: '保險權益',  url: import.meta.env.BASE_URL + 'blog/insurance/' },
  { slug: 'certification',    label: '證照進修',  url: import.meta.env.BASE_URL + 'blog/certification/' },
  { slug: 'business-planning',label: '財務規劃',  url: import.meta.env.BASE_URL + 'blog/business-planning/' },
  { slug: 'elderly-care-trust',label: '信託規劃', url: import.meta.env.BASE_URL + 'blog/elderly-care-trust/' },
  { slug: 'tax-planning',     label: '傳承稅務',  url: import.meta.env.BASE_URL + 'blog/tax-planning/' },
];
---
<nav class="blog-cat-bar">
  {categories.map(cat => (
    <a
      href={cat.url}
      class={`blog-cat-link${currentCat === cat.slug ? ' active' : ''}`}
    >{cat.label}</a>
  ))}
</nav>

<div class="blog-list">
  {posts.map(p => (
    <article class="blog-list-card">
      <a href={`${import.meta.env.BASE_URL}${p.slug}/`} class="blog-list-img-wrap">
        {p.image
          ? <img src={import.meta.env.BASE_URL + p.image.replace(/^\//, '')} alt={p.title} width="320" height="200" loading="lazy" />
          : <div class="blog-list-img-placeholder"></div>
        }
      </a>
      <div class="blog-list-body">
        <div class="blog-card-meta">
          <span>張惠芳 CFP®</span>
          <span>·</span>
          <span>{p.dateStr}</span>
          <span>·</span>
          <a href={p.catUrl}>{p.catLabel}</a>
        </div>
        <h2><a href={`${import.meta.env.BASE_URL}${p.slug}/`}>{p.title}</a></h2>
        <p class="blog-card-excerpt">{p.description.slice(0, 100)}…</p>
        <div class="blog-card-taxonomy">
          {p.catLabels && p.catLabels.map(label => (
            <span class="tax-cat">{label}</span>
          ))}
          {p.tags && p.tags.map(tag => (
            <span class="tax-tag">#{tag}</span>
          ))}
        </div>
      </div>
    </article>
  ))}
</div>

<style>
.blog-card-taxonomy {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 8px 0 12px;
}
.tax-cat {
  font-size: 13px;
  padding: 2px 10px;
  border-radius: 20px;
  background: #0d383a;
  color: #fff;
  font-weight: 600;
  white-space: nowrap;
}
.tax-tag {
  font-size: 13px;
  padding: 2px 10px;
  border-radius: 20px;
  background: #f0f4ee;
  color: #85a14f;
  border: 1px solid #85a14f;
  white-space: nowrap;
}
</style>
