---
interface PostView {
  slug: string;
  title: string;
  image?: string;
  description: string;
  dateStr: string;
  catLabel: string;
  catUrl: string;
  tags?: string[];
  catLabels?: string[];
}

interface Props {
  posts: PostView[];
  currentCat?: string;
  showCatBar?: boolean;
  layout?: 'list' | 'grid';
}

import { getAssetPath } from '../utils/assets';
import { getCategoryNavItems } from '../data/categories';
import { author } from '../data/author';

const { posts, currentCat = '', showCatBar = true, layout = 'list' } = Astro.props;
const base = import.meta.env.BASE_URL;
const catParam = currentCat ? `?cat=${currentCat}` : '?cat=all';

const categories = getCategoryNavItems(base);
---
{showCatBar && <nav class="blog-cat-bar">
  {categories.map(cat => (
    <a
      href={cat.url}
      class={`blog-cat-link${currentCat === cat.slug ? ' active' : ''}`}
    >{cat.label}</a>
  ))}
</nav>}

<div class={layout === 'grid' ? 'blog-grid' : 'blog-list'}>
  {posts.map(p => (
    <article class={layout === 'grid' ? 'blog-grid-card' : 'blog-list-card'}>
      <a href={`${base}${p.slug}/${catParam}`} class="blog-list-img-wrap">
        {p.image
          ? <img src={getAssetPath(p.image, base)} alt={p.title} width="320" height="200" loading="lazy" />
          : <div class="blog-list-img-placeholder"></div>
        }
      </a>
      <div class="blog-list-body">
        <div class="blog-card-meta">
          <a href={p.catUrl} class="blog-card-cat">{p.catLabel}</a>
          <span class="blog-card-date">{p.dateStr}</span>
        </div>
        <h2><a href={`${base}${p.slug}/${catParam}`}>{p.title}</a></h2>
        <p class="blog-card-excerpt">{p.description}</p>
        <div class="blog-card-taxonomy">
          {p.catLabels && p.catLabels.map(label => (
            <span class="tax-cat">{label}</span>
          ))}
          {p.tags && p.tags.slice(0, 3).map(tag => (
            <span class="tax-tag">#{tag}</span>
          ))}
        </div>
      </div>
    </article>
  ))}
</div>

<style>
/* ===== GRID LAYOUT (3-column for homepage) ===== */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.blog-grid-card {
  display: flex;
  flex-direction: column;
  background: var(--color-surface, #fff);
  border-radius: var(--card-radius);
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  transition: transform var(--transition), box-shadow var(--transition);
}
.blog-grid-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}
.blog-grid-card .blog-list-img-wrap {
  display: block;
  overflow: hidden;
  border-radius: 0;
}
.blog-grid-card .blog-list-img-wrap img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  aspect-ratio: 16/10;
  transition: transform var(--transition);
}
.blog-grid-card:hover .blog-list-img-wrap img { transform: scale(1.03); }
.blog-grid-card .blog-list-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 20px 24px 24px;
  flex: 1;
}
.blog-grid-card .blog-list-body h2 {
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.45;
  margin: 0;
}
.blog-grid-card .blog-list-body h2 a {
  text-decoration: none;
  color: inherit;
  transition: color var(--transition);
}
.blog-grid-card .blog-list-body h2 a:hover { color: var(--color-primary); }
@media (max-width: 900px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; gap: 20px; }
}

/* ===== LIST STYLES ===== */
.blog-card-cat {
  font-size: var(--fs-xs);
  font-weight: 600;
  text-transform: uppercase;
  color: var(--color-accent);
  text-decoration: none;
  letter-spacing: 0.05em;
}
.blog-card-cat:hover { text-decoration: underline; }
.blog-card-date {
  font-size: var(--fs-xs);
  color: var(--color-text-mid);
}
.blog-card-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}
.blog-card-taxonomy {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 8px 0 4px;
}
.tax-cat {
  font-size: var(--fs-xs);
  padding: 3px 12px;
  border-radius: 100px;
  background: var(--color-primary);
  color: var(--color-on-primary);
  font-weight: 600;
  white-space: nowrap;
}
.tax-tag {
  font-size: var(--fs-xs);
  padding: 3px 12px;
  border-radius: 100px;
  background: var(--color-accent-pale);
  color: var(--color-accent);
  border: 1px solid var(--color-border-accent);
  white-space: nowrap;
}
</style>
