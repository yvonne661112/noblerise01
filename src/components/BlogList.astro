---
interface PostView {
  slug: string;
  title: string;
  image?: string;
  description: string;
  dateStr: string;
  catLabel: string;
  catUrl: string;
  tags?: string[];
  catLabels?: string[];
}

interface Props {
  posts: PostView[];
  currentCat?: string;
  showCatBar?: boolean;
}

import { getAssetPath } from '../utils/assets';
import { getCategoryNavItems } from '../data/categories';
import { author } from '../data/author';

const { posts, currentCat = '', showCatBar = true } = Astro.props;
const base = import.meta.env.BASE_URL;

const categories = getCategoryNavItems(base);
---
{showCatBar && <nav class="blog-cat-bar">
  {categories.map(cat => (
    <a
      href={cat.url}
      class={`blog-cat-link${currentCat === cat.slug ? ' active' : ''}`}
    >{cat.label}</a>
  ))}
</nav>}

<div class="blog-list">
  {posts.map(p => (
    <article class="blog-list-card">
      <a href={`${base}${p.slug}/`} class="blog-list-img-wrap">
        {p.image
          ? <img src={getAssetPath(p.image, base)} alt={p.title} width="320" height="200" loading="lazy" />
          : <div class="blog-list-img-placeholder"></div>
        }
      </a>
      <div class="blog-list-body">
        <div class="blog-card-meta">
          <span>{author.name}</span>
          <span>·</span>
          <span>{p.dateStr}</span>
          <span>·</span>
          <a href={p.catUrl}>{p.catLabel}</a>
        </div>
        <h2><a href={`${base}${p.slug}/`}>{p.title}</a></h2>
        <p class="blog-card-excerpt">{p.description.slice(0, 60)}…</p>
        <div class="blog-card-taxonomy">
          {p.catLabels && p.catLabels.map(label => (
            <span class="tax-cat">{label}</span>
          ))}
          {p.tags && p.tags.map(tag => (
            <span class="tax-tag">#{tag}</span>
          ))}
        </div>
      </div>
    </article>
  ))}
</div>

<style>
.blog-card-taxonomy {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 8px 0 12px;
}
.tax-cat {
  font-size: var(--fs-sm);
  padding: 2px 10px;
  border-radius: 20px;
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
  white-space: nowrap;
}
.tax-tag {
  font-size: var(--fs-sm);
  padding: 2px 10px;
  border-radius: 20px;
  background: var(--color-accent-pale);
  color: var(--color-accent);
  border: 1px solid var(--color-accent);
  white-space: nowrap;
}
</style>
