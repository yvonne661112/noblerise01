---
import { CONTACT } from '../data/siteConfig';
import CompanyName from './CompanyName.astro';
const base = import.meta.env.BASE_URL;
---
<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src={base + "images/footer-logo.jpg"} alt="諾昇理財規劃" width="130" height="80" loading="lazy" />
        <p class="footer-desc">諾昇以「財務幸福」為核心，由 CFP® 張惠芳領軍，以獨立理財顧問立場提供中立、專業的財務建議，陪伴您走向財務幸福。</p>
      </div>
      <div class="footer-nav">
        <h6 class="footer-section-title">導覽</h6>
        <ul class="footer-nav-list">
          <li><a href={base}>首頁</a></li>
          <li><a href={base + "about/"}>關於諾昇</a></li>
          <li><a href={base + "service/"}>服務項目</a></li>
          <li><a href={base + "blog/"}>知識文章</a></li>
          <li><a href={base + "contact/"}>聯絡我們</a></li>
        </ul>
      </div>
      <div class="footer-contact">
        <h6 class="footer-section-title">聯絡資訊</h6>
        <ul class="footer-contact-list">
          <li><CompanyName /></li>
          <li><a href={CONTACT.lineUrl} target="_blank" rel="noopener nofollow">LINE : <span class="footer-line-id">{CONTACT.line}</span></a></li>
          <li><a href={`mailto:${CONTACT.email}`}>Email：{CONTACT.email}</a></li>
          <li>地址：{CONTACT.address}</li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-copy">
    <p>&copy; 2026 {CONTACT.companyNameZh} All Rights Reserved.</p>
  </div>
</footer>

<style>
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .footer-brand img { margin-bottom: 16px; }
  .footer-desc {
    font-size: var(--fs-base);
    line-height: 1.8;
    color: var(--color-text-muted);
  }
  .footer-section-title {
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-light);
    margin-bottom: 20px;
  }
  .footer-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-nav-list li { margin-bottom: 10px; }
  .footer-nav-list a {
    color: var(--color-text-muted);
    font-size: var(--fs-base);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-nav-list a:hover { color: var(--color-on-primary); }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
