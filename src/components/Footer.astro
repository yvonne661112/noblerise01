---
import { CONTACT, SHOW_FOOTER_SUB_NAV } from '../data/siteConfig';
import { mainNav } from '../data/navLinks';
const base = import.meta.env.BASE_URL;
---
<footer class="site-footer">
  <div class="footer-main">
    <!-- 三欄：Logo 左 ｜ 導覽中 ｜ 公司資訊右，頂部對齊 -->
    <div class="footer-content">
      <div class="footer-logo-col">
        <a href={base}><img src={base + "images/footer-logo-new.jpg"} alt="諾昇理財規劃" width="200" loading="lazy" /></a>
      </div>

      <nav class="footer-nav-col" aria-label="頁尾導覽">
        <ul class="footer-nav-list">
          {mainNav.filter(item => !item.hidden).map(item => (
            <li>
              <a href={base + item.href}>{item.label}</a>
              {SHOW_FOOTER_SUB_NAV && item.children && (
                <ul class="footer-sub-list">
                  {item.children.map(child => (
                    <li><a href={base + child.href}>{child.label}</a></li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer-info-col">
        <p class="footer-company-zh">{CONTACT.companyNameZh}</p>
        <p class="footer-company-en">{CONTACT.companyNameEn}</p>
        <ul class="footer-info-list">
          <li><a href={CONTACT.lineUrl} target="_blank" rel="noopener nofollow">LINE：<span class="footer-line-id">{CONTACT.line}</span></a></li>
          <li><a href={`mailto:${CONTACT.email}`}>Email：{CONTACT.email}</a></li>
          <li><a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(CONTACT.address)}`} target="_blank" rel="noopener nofollow">地址：{CONTACT.address}</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-copy">
    <p>&copy; 2026 {CONTACT.companyNameZh} All Rights Reserved.</p>
  </div>
</footer>
