---
import { author } from '../data/author';

const base = import.meta.env.BASE_URL;
const certs = author.certifications.split('、');
const awards = author.awards.split('、');
---

<div class="author-card">
  <div class="author-card-body">

    <div class="author-name">作者｜{author.name}</div>

    <div class="author-rows">
      <div class="author-row">
        <span class="author-key">現職</span>
        <span class="author-val">{author.position}</span>
      </div>
      <div class="author-row">
        <span class="author-key">專長</span>
        <span class="author-val">{author.specialties}</span>
      </div>
      <div class="author-row">
        <span class="author-key">證照</span>
        <span class="author-val">{certs.join('、')}</span>
      </div>
      <div class="author-row">
        <span class="author-key">獲獎</span>
        <span class="author-val">
          <span class="author-award-tags">
            {awards.map(a => <span class="author-award">{a.trim()}</span>)}
          </span>
        </span>
      </div>
      <div class="author-row">
        <span class="author-key">網站</span>
        <span class="author-val"><a href={author.website} target="_blank" rel="noopener">{author.website.replace(/\/$/, '')}</a></span>
      </div>
    </div>

    <a href={`${base}about/`} class="author-more-link">了解更多關於 {author.name} →</a>

  </div>

  <div class="author-divider"></div>

  <div class="author-cta">
    <div>
      <div class="author-cta-text">這篇文章對您有幫助嗎？</div>
      <div class="author-cta-sub">讓 CFP® 為您做一次專屬的財務健康檢查</div>
    </div>
    <a href="https://line.me/R/ti/p/@noblerise" target="_blank" rel="noopener" class="author-cta-btn">預約免費諮詢</a>
  </div>
</div>

<style>
.author-card {
  margin-top: 56px;
  border-radius: var(--card-radius);
  border: 1px solid var(--color-border);
  overflow: hidden;
  background: var(--color-white);
}
.author-card-body {
  padding: 24px 28px;
}
.author-name {
  font-size: var(--fs-2xl);
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 16px;
}
.author-cert-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-bottom: 16px;
}
.author-cert-tag {
  font-size: var(--fs-sm);
  color: var(--color-white);
  background: var(--color-primary);
  border-radius: 20px;
  padding: 6px 15px;
  font-weight: 500;
}
.author-rows {
  display: flex;
  flex-direction: column;
  gap: 9px;
}
.author-row {
  display: flex;
  gap: 12px;
  font-size: var(--fs-base);
  line-height: 1.7;
}
.author-key {
  color: var(--color-accent);
  font-weight: 600;
  flex-shrink: 0;
  min-width: 36px;
  font-size: var(--fs-sm);
}
.author-key::after {
  content: '';
}
.author-val {
  color: var(--color-text);
  font-size: var(--fs-base);
}
.author-val a {
  color: var(--color-primary);
  text-decoration: none;
  word-break: break-all;
}
.author-val a:hover {
  text-decoration: underline;
}
.author-award-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}
.author-award {
  font-size: var(--fs-xs);
  background: var(--color-accent-pale);
  color: var(--color-accent);
  padding: 3px 10px;
  border-radius: 8px;
}
.author-more-link {
  display: block;
  margin-top: 14px;
  font-size: var(--fs-base);
  font-weight: 500;
  color: var(--color-primary);
  text-decoration: none;
}
.author-more-link:hover {
  text-decoration: underline;
}
.author-divider {
  height: 1px;
  background: var(--color-border);
}
.author-cta {
  background: var(--color-primary);
  padding: 20px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  flex-wrap: wrap;
}
.author-cta-text {
  font-size: var(--fs-body);
  font-weight: 500;
  color: var(--color-white);
  margin-bottom: 3px;
}
.author-cta-sub {
  font-size: var(--fs-sm);
  color: rgba(255, 255, 255, 0.6);
}
.author-cta-btn {
  display: inline-block;
  background: var(--color-white);
  color: var(--color-primary);
  border: none;
  border-radius: var(--card-radius);
  padding: 10px 20px;
  font-size: var(--fs-sm);
  font-weight: 500;
  text-decoration: none;
  white-space: nowrap;
}
.author-cta-btn:hover {
  opacity: 0.9;
}
</style>
