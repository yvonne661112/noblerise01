---
import { author } from '../data/author';
---

<div class="author-card">
  <div class="author-card-header">
    <div>
      <span class="author-label">作者</span>
      <span class="author-name">{author.name}</span>
    </div>
    <span class="author-title">{author.title}</span>
  </div>
  <div class="author-card-body">
    <div class="author-detail-row">
      <span class="detail-label">現職</span>
      <span>{author.position}</span>
    </div>
    <div class="author-detail-row">
      <span class="detail-label">證照</span>
      <span>{author.certifications}</span>
    </div>
    <div class="author-detail-row">
      <span class="detail-label">專長</span>
      <span>{author.specialties}</span>
    </div>
    <div class="author-detail-row">
      <span class="detail-label">獲獎</span>
      <span>{author.awards}</span>
    </div>
    <div class="author-detail-row">
      <span class="detail-label">網站</span>
      <span><a href={author.website} target="_blank" rel="noopener">{author.website}</a></span>
    </div>
    <a href={`${import.meta.env.BASE_URL}about/`} class="author-more-link">了解更多關於 {author.name} →</a>
  </div>
</div>

<style>
.author-card {
  margin-top: 56px;
  padding: 28px 32px;
  border-left: 4px solid var(--color-accent);
  background: var(--color-bg-subtle);
  border-radius: 0 var(--card-radius) var(--card-radius) 0;
}
.author-card-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--color-border);
  flex-wrap: wrap;
}
.author-label {
  font-size: var(--fs-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  margin-right: 8px;
}
.author-name {
  font-family: var(--font-heading);
  font-weight: var(--heading-weight);
  color: var(--color-primary);
  font-size: var(--fs-2xl);
}
.author-title {
  color: var(--color-text-mid);
  font-size: var(--fs-sm);
}
.author-card-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.author-detail-row {
  display: flex;
  gap: 12px;
  font-size: var(--fs-base);
  color: var(--color-text);
  line-height: 1.7;
}
.detail-label {
  flex-shrink: 0;
  font-weight: 600;
  color: var(--color-primary);
  min-width: 36px;
  font-size: var(--fs-sm);
}
.detail-label::after {
  content: '：';
}
.author-detail-row a {
  color: var(--color-accent);
  word-break: break-all;
}
.author-detail-row a:hover {
  text-decoration: underline;
}
.author-more-link {
  display: inline-block;
  margin-top: 16px;
  font-size: var(--fs-base);
  font-weight: 600;
  color: var(--color-accent);
  text-decoration: none;
}
.author-more-link:hover {
  text-decoration: underline;
}
</style>
